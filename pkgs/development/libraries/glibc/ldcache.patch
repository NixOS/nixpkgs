+         --build-resolution-cache.  Consulted after LD_LIBRARY_PATH so that
+         overrides keep working; it replaces the DT_RUNPATH directory walk for
+         the dependencies it records.  */
+      if (fd == -1 && (rescache = _dl_lookup_nixos_cache (loader, name)) != NULL)
+        {
+          char *tmp = rescache;
+          char *iter;
+          while ((iter = strsep (&tmp, ":")) != NULL)
+            {
+              if (iter[0] == '?')
+                {
+                  /* A directory the loader must still search itself.  */
+                  struct r_search_path_struct sp;
+                  sp.dirs = NULL;
+                  if (decompose_rpath (&sp, iter + 1, loader, "RESCACHE"))
+                    {
+                      fd = open_path (name, namelen, mode, &sp, &realname,
+                                      &fb, loader, LA_SER_RUNPATH,
+                                      &found_other_class);
+                      if (sp.dirs != (void *) -1)
+                        free (sp.dirs);
+                    }
+                }
+              else if (iter[0] == '=')
+                {
+                  /* An exact path; open it directly.  */
+                  realname = __strdup (iter + 1);
+                  if (realname != NULL)
+                    {
+                      fd = open_verify (realname, -1, &fb,
+                                        loader ?: GL(dl_ns)[nsid]._ns_loaded,
+                                        LA_SER_RUNPATH, mode,
+                                        &found_other_class, false);
+                      if (fd == -1)
+                        free (realname);
+                    }
+                }
+              if (fd != -1)
+                break;
+            }
+          free (rescache);
+        }
+
       /* Look at the RUNPATH information for this binary.  */
       if (fd == -1 && loader != NULL
 	  && cache_rpath (loader, &loader->l_runpath_dirs,
