--- a/deps/uv/src/unix/kqueue.c
+++ b/deps/uv/src/unix/kqueue.c
@@ -290,9 +290,14 @@
                   ARRAY_SIZE(events),
                   timeout == -1 ? NULL : &spec);

-    if (nfds == -1)
-      assert(errno == EINTR);
-    else if (nfds == 0)
+    if (nfds == -1) {
+      /* kevent() can fail with EINTR (signal), EBADF (closed fd still in
+       * changelist), or ENOENT (fd removed between changelist submit and
