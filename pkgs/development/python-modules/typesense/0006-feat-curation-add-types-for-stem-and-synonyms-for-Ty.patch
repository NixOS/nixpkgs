                 },
                 "stop_processing": True,
             },
@@ -263,6 +270,8 @@ async def test_actual_list_items_async(
             "rule": {
                 "match": "contains",
                 "query": "shoe",
+                "stem": False,
+                "synonyms": False,
             },
             "stop_processing": True,
         },
@@ -295,6 +304,8 @@ async def test_actual_get_item_async(
         "rule": {
             "match": "contains",
