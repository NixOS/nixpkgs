{
  lib,
  buildPythonPackage,
  fetchFromGitHub,
  setuptools,
}:

buildPythonPackage (finalAttrs: {
  pname = "mycdp";
  version = "1.3.7";
  pyproject = true;

  src = fetchFromGitHub {
    owner = "mdmintz";
    repo = "MyCDP";
    tag = "v${finalAttrs.version}";
    hash = "sha256-ofPWVEnqfOKdeEzVO6LqXZS0weeocbr+8kcPgaF4fTI=";
  };

  build-system = [
    setuptools
  ];

  # No tests
  doCheck = false;

  pythonImportsCheck = [ "mycdp" ];

  meta = {
    changelog = "https://github.com/mdmintz/MyCDP/releases/tag/v${finalAttrs.version}";
    description = "Autogenerated CDP utilities for Python";
    homepage = "https://github.com/mdmintz/MyCDP";
    license = lib.licenses.mit;
    maintainers = with lib.maintainers; [
      pyrox0
    ];
  };
})
