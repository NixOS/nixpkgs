From: matthewcroughan <matt@croughan.sh>
Date: Fri, 23 May 2025 15:31:27 +0100
Subject: [PATCH] use module_init

---
 0001-use-module_init.patch                    | 34 +++++++++++++++++++
 .../src/Unix/Linux/NetDriver/sheep_net.c      | 12 +++----
 2 files changed, 40 insertions(+), 6 deletions(-)
 create mode 100644 0001-use-module_init.patch

diff --git a/0001-use-module_init.patch b/0001-use-module_init.patch
new file mode 100644
index 00000000..b5190eb0
--- /dev/null
+++ b/0001-use-module_init.patch
@@ -0,0 +1,34 @@
+From 0a8f823ccc33b11fcf1812a7cdfba8b65c81a007 Mon Sep 17 00:00:00 2001
+From: matthewcroughan <matt@croughan.sh>
+Date: Fri, 23 May 2025 15:31:27 +0100
+Subject: [PATCH] use module_init
+
+---
+ sheep_net.c | 4 ++--
+ 1 file changed, 2 insertions(+), 2 deletions(-)
+
+diff --git a/sheep_net.c b/sheep_net.c
+index 40781fce..1501cb59 100644
+--- a/sheep_net.c
++++ b/sheep_net.c
+@@ -220,8 +220,7 @@ static struct proto sheep_proto = {
+ /*
+  *  Initialize module
+  */
+-
+-int init_module(void)
++static int __init sheep_net_init(void)
+ {
+ 	int ret;
+ 
+@@ -231,6 +230,7 @@ int init_module(void)
+ 	return ret;
+ }
+ 
++module_init(sheep_net_init);
+ 
+ /*
+  *  Deinitialize module
+-- 
+2.49.0
+
diff --git a/sheep_net.c b/sheep_net.c
index 40781fce..9cf9adba 100644
--- a/sheep_net.c
+++ b/sheep_net.c
@@ -220,8 +220,7 @@ static struct proto sheep_proto = {
 /*
  *  Initialize module
  */
-
-int init_module(void)
+static int __init sheep_net_init(void)
 {
 	int ret;
 
@@ -231,18 +230,19 @@ int init_module(void)
 	return ret;
 }
 
+module_init(sheep_net_init);
 
 /*
  *  Deinitialize module
  */
 
-void cleanup_module(void)
+static void __exit sheep_net_exit(void)
 {
-	/* Unregister driver */
-	misc_deregister(&sheep_net_device);
-	printk("sheep net: driver removed\n");
+    misc_deregister(&sheep_net_device);
+    printk(KERN_INFO "sheep net: driver removed\n");
 }
 
+module_exit(sheep_net_exit);
 
 /*
  *  Driver open() function
-- 
2.49.0
