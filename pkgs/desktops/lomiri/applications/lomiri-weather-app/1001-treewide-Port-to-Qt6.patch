+                        height: width
+                        source: "qrc:/extended-information_chance-of-sleet.svg"
+                    }
+
+                    Label {
+                        id: precipPropLabel
+                        Layout.alignment: Qt.AlignRight
+                        font.pixelSize: units.gu(2.2)
