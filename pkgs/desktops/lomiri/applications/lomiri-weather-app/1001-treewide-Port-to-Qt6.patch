diff --git a/CMakeLists.txt b/CMakeLists.txt
index 42b37598..69c8b312 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -50,21 +50,44 @@ if(NOT flatbuffers_FOUND)
 endif()
 message(STATUS "Found a flatbuffers CMake module")
 
-find_package(Qt5Core REQUIRED)
-find_package(Qt5Qml REQUIRED)
-find_package(Qt5Quick REQUIRED)
-find_package(Qt5QuickControls2 REQUIRED)
-find_package(Qt5Location REQUIRED)
-find_package(Qt5WebEngine REQUIRED)
-
 # Automatically create moc files
 set(CMAKE_AUTOMOC ON)
 
+option(ENABLE_QT6 "Enable building with Qt6" OFF)
 option(INSTALL_TESTS "Install the tests on make install" on)
 option(CLICK_MODE "Build as a click package" on)
 option(CONNECTIVITY_CHECK "Enable checking whether the user is offline (needs lomiri-indicator-network)" on)
 set(OWM_API_KEY "" CACHE STRING "OpenWeatherMap API key")
 
+set(QT_VERSION_MAJOR)
+set(QT_COMPONENTS Core Gui Location Qml Quick QuickControls2)
+if(ENABLE_QT6)
+    set(QT_VERSION_MAJOR 6)
+    list(APPEND QT_COMPONENTS WebEngineQuick)
+else()
+    set(QT_VERSION_MAJOR 5)
+    list(APPEND QT_COMPONENTS WebEngine)
+endif()
+
+find_package(QT NAMES Qt${QT_VERSION_MAJOR})
+find_package(Qt${QT_VERSION_MAJOR} REQUIRED COMPONENTS ${QT_COMPONENTS})
+
+# 20.04 clickable SDK is on 5.12. Backport some things that make Qt5/Qt6 usage more straight-forward
+if(QT_VERSION VERSION_LESS "5.15")
+    function(qt_add_resources outfiles)
+        qt5_add_resources("${outfiles}" ${ARGN})
+        set("${outfiles}" "${${outfiles}}" PARENT_SCOPE)
+    endfunction()
+    foreach(QT5_COMPONENT IN LISTS QT_COMPONENTS)
+        if(NOT TARGET Qt::${QT5_COMPONENT})
+            add_library(Qt::${QT5_COMPONENT} INTERFACE IMPORTED)
+            set_target_properties(Qt::${QT5_COMPONENT} PROPERTIES
+                INTERFACE_LINK_LIBRARIES "Qt5::${QT5_COMPONENT}"
+            )
+        endif()
+    endforeach()
+endif()
+
 # Tests
 enable_testing()
 
