+ * GNU General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License
+ * along with this program.  If not, see <http://www.gnu.org/licenses/>.
+ */
+
+import QtQuick 2.12
+import Lomiri.Components
+
+Rectangle {
+    id: indicator
+    objectName: "processingIndicator"
+    height: units.dp(3)
+    color: theme.palette.normal.background
+    opacity: 0
+    visible: opacity > 0
+
+    property bool processing: false
+
+    Behavior on opacity {
+        LomiriNumberAnimation { duration: LomiriAnimation.FastDuration }
+    }
+
+    onProcessingChanged: {
+        if (processing) delay.start();
+        else if (!persist.running) indicator.opacity = 0;
+    }
+
+    Timer {
+        id: delay
+        interval: 200
+        onTriggered: if (indicator.processing) {
+            persist.restart();
+            indicator.opacity = 1;
+        }
+    }
+
+    Timer {
+        id: persist
+        interval: 2 * LomiriAnimation.SleepyDuration - LomiriAnimation.FastDuration
+        onTriggered: if (!indicator.processing) indicator.opacity = 0
+    }
+
+    Rectangle {
+        id: orange
+        anchors { top: parent.top;  bottom: parent.bottom }
+        width: parent.width / 4
+        color: LomiriColors.orange
+
+        SequentialAnimation {
+            running: indicator.visible
+            loops: Animation.Infinite
+            XAnimator {
+                from: -orange.width / 2
+                to: indicator.width - orange.width / 2
+                duration: LomiriAnimation.SleepyDuration
+                easing.type: Easing.InOutSine
+                target: orange
+            }
+            XAnimator {
+                from: indicator.width - orange.width / 2
+                to: -orange.width / 2
+                duration: LomiriAnimation.SleepyDuration
+                easing.type: Easing.InOutSine
+                target: orange
+            }
+        }
+    }
+}
