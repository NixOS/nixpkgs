+        State {
+            name: "expanded"
+            PropertyChanges {
+                target: currentInfoItem
+                height: expandedHeight
+            }
+            PropertyChanges {
+                target: expandedInfo
+                opacity: 1
+            }
+            PropertyChanges {
+                target: updownIcon
+                name: "up"
+            }
+        }
