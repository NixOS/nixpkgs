index 00000000..51a25c19
--- /dev/null
+++ b/src/app/qml-qt6/data/moonphase.js
@@ -0,0 +1,52 @@
+function getMoonPhaseString(forecastDateStart,forecastDateEnd) {
+    // moonphase fraction is returned as value between 0 and 1,
+    // calculate the moonphase fraction for start of day (= 00:00:00) and end of day (= 23:59:59)
+    // compare start and end fraction against moonphase values to set the name of the moonphase
+    var dayStart = sunCalc.getMoonIllumination(forecastDateStart).phase;
+    var dayEnd = sunCalc.getMoonIllumination(forecastDateEnd).phase;
+    var moonPhaseString = "";
+    var moonEmoji ="";
+    var moonImage ="";
+
+    if (dayStart > dayEnd) {
+        moonPhaseString = i18n.tr("New moon");
+        moonEmoji = "\uD83C\uDF11";
+        moonImage = "qrc:/moon-phase-1-new-moon.svg";
+    } else if (dayStart > 0.00 && dayEnd < 0.25) {
+        moonPhaseString = i18n.tr("Waxing Crescent");
+        moonEmoji = "\uD83C\uDF12";
+        moonImage = "qrc:/moon-phase-2-waxing-crescent.svg";
+    } else if (dayStart <= 0.25 && dayEnd >= 0.25) {
+        moonPhaseString = i18n.tr("First Quarter");
+        moonEmoji = "\uD83C\uDF13";
+        moonImage = "qrc:/moon-phase-3-first-quarter.svg";
+    } else if (dayStart > 0.25 && dayEnd < 0.50) {
+        moonPhaseString = i18n.tr("Waxing Gibbous");
+        moonEmoji = "\uD83C\uDF14";
+        moonImage = "qrc:/moon-phase-4-waxing-gibbous.svg";
+    } else if (dayStart <= 0.50 && dayEnd >= 0.50) {
+        moonPhaseString = i18n.tr("Full moon");
+        moonEmoji = "\uD83C\uDF15";
+        moonImage = "qrc:/moon-phase-5-full-moon.svg";
+    } else if (dayStart > 0.50 && dayEnd < 0.75) {
+        moonPhaseString = i18n.tr("Waning Gibbous");
+        moonEmoji = "\uD83C\uDF16";
+        moonImage = "qrc:/moon-phase-6-waning-gibbous.svg";
+    } else if (dayStart <= 0.75 && dayEnd >= 0.75) {
+        moonPhaseString = i18n.tr("Last Quarter");
+        moonEmoji = "\uD83C\uDF17";
+        moonImage = "qrc:/moon-phase-7-third-quarter.svg";
+    } else if (dayStart > 0.75 && dayEnd < 1.00) {
+        moonPhaseString = i18n.tr("Waning Crescent");
+        moonEmoji = "\uD83C\uDF18";
+        moonImage = "qrc:/moon-phase-8-waning-crescent.svg";
+    } else {
+        moonPhaseString = i18n.tr("calculation error");
+    }
+
+    return {
+      moonphase: moonPhaseString,
+      moonemoji: moonEmoji,
+      moonimage: moonImage,
+    }
+}
