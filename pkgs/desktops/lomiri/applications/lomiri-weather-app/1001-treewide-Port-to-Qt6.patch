+                width: upperRow.fixedWidth
+                spacing: units.gu(1.25)
+
+                Icon {
+                    id: moonImage
+                    Layout.alignment: Qt.AlignHCenter
+                    height: units.gu(2.5)
+                    width: height
+                    source:  modelData.moonImage
+                }
+
+                Icon {
+                    id: weatherImage
+                    // hide weather image if there is not enough space available to show all content, since this is the least important one
+                    visible: !upperRow.hasLimitedSpace
+                    Layout.alignment: Qt.AlignHCenter
+                    height: units.gu(3)
+                    width: height
+                }
+
+                Icon {
+                    id: lowImage
+                    Layout.alignment: Qt.AlignHCenter
+                    height: units.gu(2)
+                    width: height
+                    source: "qrc:/extended-information_moon.svg"
+                    color: settings.lowColor
+                }
+
+                Label {
+                    id: lowLabel
+                    //because Fahrenheit can go above 100 for three digits more space is needed
+                    Layout.preferredWidth: settings.tempScale === "°F" || parseFloat(low) <= -10 ? units.gu(4.5) : units.gu(4)
+                    Layout.alignment: Qt.AlignHCenter
+                    color: settings.lowColor
+                    font.weight: Font.Normal
+                    font.pixelSize: units.gu(2.2)
+                    horizontalAlignment: Text.AlignRight
+                }
+
+                Icon {
+                    id: highImage
+                    Layout.alignment: Qt.AlignHCenter
+                    height: units.gu(2)
+                    width: height
+                    name: "weather-clear-symbolic"
