+                service_id: `${coordinate.latitude}x${coordinate.longitude}`,
+            };
+
+            location.data = forecast.map((day, i) => ({
+                date: breakDate(day.data.timestamp),
+                timestamp: day.data.timestamp.getTime() / 1000,
+                metric: {
