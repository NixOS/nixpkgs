+            property var fixedWidth: settings.tempScale === "°F" || parseFloat(low) <= -10 || parseFloat(high) <= -10 ? units.gu(28) : units.gu(27)
+            property var flexibleWidth: parent.width - fixedWidth
+            property bool hasLimitedSpace: flexibleWidth > units.gu(11) ? false : true
+
+            Label {
+                id: dayLabel
+                Layout.alignment: Qt.AlignLeft
+                //the remaining space of total width minus margins minus fixedWidthItemsRow
+                width: upperRow.flexibleWidth
+                elide: Text.ElideRight
