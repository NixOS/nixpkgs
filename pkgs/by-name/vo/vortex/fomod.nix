# FOMOD installer build scripts — IPC (TypeScript fallback) and
# Native AOT (C# → .so → N-API bridge → webpack).
{lib}: let
  ipcDir = "extensions/fomod-installer/src/ModInstaller.IPC.TypeScript";
  nativeDir = "extensions/fomod-installer/src/ModInstaller.Native.TypeScript";
  # Relative to nativeDir (sibling directory, used inside pushd)
  nativeCsharpRel = "../ModInstaller.Native";
in {
  # Install yarn deps for both FOMOD TypeScript projects
  installDeps = lib.concatMapStringsSep "\n" (dir: ''
    pushd ${dir}
    yarn install \
      --force \
      --ignore-engines \
      --ignore-platform \
      --ignore-scripts \
      --no-progress \
      --non-interactive \
      --offline || true
    patchShebangs node_modules 2>/dev/null || true
    popd
  '') [ipcDir nativeDir];

  # IPC: full tsc + webpack (JS bundle needed at runtime as fallback,
  # declarations needed by main build). No dotnet publish — Native AOT
  # handles FOMOD at runtime.
  buildIPC = ''
    pushd ${ipcDir}
    node_modules/.bin/tsc
    node_modules/.bin/webpack --config webpack.config.js
    popd
  '';

  # Native AOT: 5-stage pipeline
  #   1. dotnet publish (Native AOT → .so + .h)
  #   2. Copy native artifacts
  #   3. node-gyp rebuild (C++ N-API bridge)
  #   4. Assemble dist/ with RPATH fix
  #   5. TypeScript declarations + webpack
  buildNativeAOT = ''
    pushd ${nativeDir}

    # Stage 1: dotnet publish (Native AOT → .so + .h)
    dotnet publish ${nativeCsharpRel} \
      --self-contained -c Release -o "$(pwd)/build-dotnet"

    # Stage 2: Copy native artifacts to cwd (where binding.gyp expects them)
    cp build-dotnet/ModInstaller.Native.so .
    # The .h is generated by BUTR.NativeAOT.Generator; may land in publish dir,
    # project source dir, or obj/ depending on MSBuild ordering.
    cp build-dotnet/ModInstaller.Native.h . 2>/dev/null \
      || cp ${nativeCsharpRel}/ModInstaller.Native.h . 2>/dev/null \
      || find ${nativeCsharpRel} -name ModInstaller.Native.h -exec cp {} . \;

    # Stage 3: node-gyp rebuild (builds C++ N-API bridge linking the .so)
    node_modules/.bin/node-gyp rebuild --arch=x64 --release

    # Stage 4: Assemble dist/
    # Set RPATH to $ORIGIN so modinstaller.node finds ModInstaller.Native.so
    # alongside it at runtime (otherwise it has /build/ paths)
    patchelf --set-rpath '$ORIGIN' build/Release/modinstaller.node
    mkdir -p dist
    cp ModInstaller.Native.so dist/
    cp build/Release/modinstaller.node dist/

    # Stage 5: TypeScript declarations + webpack
    node_modules/.bin/tsc --emitDeclarationOnly
    node_modules/.bin/webpack --config webpack.config.js

    popd
  '';

  # Sync dist/ dirs to root + app node_modules
  # (yarn copies file: deps at install time, so builds aren't visible there)
  syncDists = ''
    cp -r ${ipcDir}/dist node_modules/fomod-installer-ipc/
    cp -r ${nativeDir}/dist node_modules/fomod-installer-native/

    cp -r ${ipcDir}/dist app/node_modules/fomod-installer-ipc/
    cp -r ${nativeDir}/dist app/node_modules/fomod-installer-native/
  '';
}
