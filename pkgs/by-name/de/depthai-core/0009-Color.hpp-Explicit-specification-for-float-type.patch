From 0d17b37b180b22daf522c0f3b0108ce5a65f2617 Mon Sep 17 00:00:00 2001
From: Petr Hodina <petr.hodina@luxonis.com>
Date: Fri, 21 Mar 2025 07:36:55 +0100
Subject: [PATCH 09/14] Color.hpp: Explicit specification for float type


diff --git a/include/depthai/common/Color.hpp b/include/depthai/common/Color.hpp
index 38e80b236..f649445d2 100644
--- a/include/depthai/common/Color.hpp
+++ b/include/depthai/common/Color.hpp
@@ -26,7 +26,7 @@ struct Color {
     Color(float r, float g, float b, float a) {
         // r,g,b,a values should be in range [0.0, 1.0]
         auto check = [](float val) -> float {
-            if(val < 0.0 || val > 1.0) {
+            if(val < (float) 0.0 || val > (float) 1.0) {
                 throw std::invalid_argument("Color values should be in range [0.0, 1.0]");
             }
             return val;
