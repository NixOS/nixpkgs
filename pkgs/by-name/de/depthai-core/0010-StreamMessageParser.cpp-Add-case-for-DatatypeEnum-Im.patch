Subject: [PATCH 10/14] StreamMessageParser.cpp: Add case for
 DatatypeEnum::ImgAnnotations


diff --git a/src/pipeline/datatype/StreamMessageParser.cpp b/src/pipeline/datatype/StreamMessageParser.cpp
index e21be4010..d43b55771 100644
--- a/src/pipeline/datatype/StreamMessageParser.cpp
+++ b/src/pipeline/datatype/StreamMessageParser.cpp
@@ -243,6 +243,8 @@ std::shared_ptr<ADatatype> StreamMessageParser::parseMessage(streamPacketDesc_t*
         case DatatypeEnum::TransformData:
             return parseDatatype<TransformData>(metadataStart, serializedObjectSize, data, fd);
             break;
+        case DatatypeEnum::ImgAnnotations:
+            break;
     }
 
     throw std::runtime_error("Bad packet, couldn't parse");
