{
  lib,
  buildGoModule,
  fetchFromGitHub,
  installShellFiles,
  makeWrapper,

  # Runtime dependencies
  containerd,
  etcd_3_6,
  iptables,
  keepalived,
  kine,
  kubernetes,
  runc,
}:
let
  version = "1.35.2+k0s.0";
  tag = "v${version}";

  # Pinned versions and hashes for all components bundled with k0s.
  # Source: embedded-bins/Makefile.variables. Keep in sync when upgrading k0s.
  deps = {
    runc = {
      version = "1.4.1";
      hash = "sha256-YqzRHItk8gRDBQN+lUTGdbXUf+vuDIjmErDR57Ec/54=";
    };
    containerd = {
      version = "1.7.30";
      hash = "sha256-P6j6BYptuPGmAOhVeG0S78dv9OzAC1IBNBbbaCZhRoQ=";
    };
    kubernetes = {
      version = "1.35.2";
      hash = "sha256-cmR5ugxeBC0RsrvQ38zK6/5QGptAfTk6bXo53XHkU2s=";
    };
    kine = {
      version = "0.14.14";
      hash = "sha256-G1GVR0bgcx51HqwsCUqd9H30mWZgLkYYy2PNdmO/oQw=";
      vendorHash = "sha256-N5FEspfnc6GexPIzN5PbX8/XYD0LXledE+mi9Ni0gTU=";
    };
    konnectivity = {
      version = "0.34.0";
      hash = "sha256-oBb+ix9N3QIXkp2QCr98ZJTvD7hAloc7nTXX6+gSCc4=";
    };
    iptables = {
      version = "1.8.11";
    };
    keepalived = {
      version = "2.3.4";
      hash = "sha256-Xv/UGIeZhRHQO5lxkaWgHDUW+3qBi3wFU4+Us1A2uE0=";
    };
  };

  k0sRunc = runc.overrideAttrs (old: {
    version = deps.runc.version;
    src = old.src.override {
      tag = "v${deps.runc.version}";
      hash = deps.runc.hash;
    };
  });

  # k0s 1.35.2 expects containerd 1.7.30; nixpkgs ships 2.x, so pin the source.
  k0sContainerd = containerd.overrideAttrs (
    old:
    let
      newSrc = old.src.override {
        tag = "v${deps.containerd.version}";
        hash = deps.containerd.hash;
      };
    in
    {
      version = deps.containerd.version;
      src = newSrc;
      # containerd 1.7.x has only a single output; install-doc/install-man were added in 2.x.
      outputs = [ "out" ];
      installTargets = [ "install" ];
      # Update VERSION and REVISION; preserve BUILDTAGS from the original.
      makeFlags = map (
        f:
        if lib.hasPrefix "REVISION=" f then
          "REVISION=${newSrc.rev}"
        else if lib.hasPrefix "VERSION=" f then
          "VERSION=v${deps.containerd.version}"
        else
          f
      ) old.makeFlags;
    }
  );

  k0sKubernetes = kubernetes.overrideAttrs (old: {
    version = deps.kubernetes.version;
    src = old.src.override {
      tag = "v${deps.kubernetes.version}";
      hash = deps.kubernetes.hash;
    };
  });

  k0sKine = kine.overrideAttrs (old: {
    version = deps.kine.version;
    src = old.src.override {
      rev = "v${deps.kine.version}";
      hash = deps.kine.hash;
    };
    vendorHash = deps.kine.vendorHash;
  });

  konnectivityServer = buildGoModule {
    pname = "konnectivity-server";
    version = deps.konnectivity.version;

    src = fetchFromGitHub {
      owner = "kubernetes-sigs";
      repo = "apiserver-network-proxy";
      tag = "v${deps.konnectivity.version}";
      hash = deps.konnectivity.hash;
    };

    # Dependencies are vendored in the source tree.
    vendorHash = null;

    subPackages = [ "cmd/server" ];

    ldflags = [
      "-s"
      "-w"
    ];

    postInstall = ''
      mv $out/bin/server $out/bin/konnectivity-server
    '';

    meta = {
      description = "Konnectivity server (apiserver-network-proxy) for Kubernetes connectivity";
      homepage = "https://github.com/kubernetes-sigs/apiserver-network-proxy";
      license = lib.licenses.asl20;
      platforms = lib.platforms.linux;
    };
  };

  runtimeDeps = [
    k0sRunc
    k0sContainerd
    etcd_3_6
    k0sKine
    k0sKubernetes
    iptables
    konnectivityServer
    keepalived
  ];
in
buildGoModule {
  pname = "k0s";
  inherit version;

  src = fetchFromGitHub {
    owner = "k0sproject";
    repo = "k0s";
    inherit tag;
    hash = "sha256-bPXCQAOTLMhGRoB55RBEegFiQqvPjw9+/Wb0sgUeSQM=";
  };

  vendorHash = "sha256-Lx9YTeOTIK8CDv0RfMz+v3rAcC/zYXtLtXRZxqhbakw=";

  nativeBuildInputs = [
    installShellFiles
    makeWrapper
  ];

  tags = [
    "osusergo"
    "noembedbins"
  ];

  # Mirror the ldflags generated by:
  #   make DOCKER='' EMBEDDED_BINS_BUILDMODE=none BUILD_GO_LDFLAGS_EXTRA=''
  # Keep these in sync with deps.* when upgrading.
  ldflags = [
    "-w"
    "-s"
    "-X github.com/k0sproject/k0s/pkg/build.Version=v${version}"
    "-X github.com/k0sproject/k0s/pkg/build.RuncVersion=${k0sRunc.version}"
    "-X github.com/k0sproject/k0s/pkg/build.ContainerdVersion=${k0sContainerd.version}"
    "-X github.com/k0sproject/k0s/pkg/build.KubernetesVersion=${k0sKubernetes.version}"
    "-X github.com/k0sproject/k0s/pkg/build.KineVersion=${k0sKine.version}"
    "-X github.com/k0sproject/k0s/pkg/build.EtcdVersion=${etcd_3_6.version}"
    "-X github.com/k0sproject/k0s/pkg/build.KonnectivityVersion=${konnectivityServer.version}"
    "-X github.com/k0sproject/k0s/pkg/build.EulaNotice="
    "-X github.com/k0sproject/k0s/pkg/telemetry.segmentToken="
    "-X k8s.io/component-base/version.gitVersion=v${k0sKubernetes.version}"
    "-X k8s.io/component-base/version.gitMajor=${lib.versions.major k0sKubernetes.version}"
    "-X k8s.io/component-base/version.gitMinor=${lib.versions.minor k0sKubernetes.version}"
    "-X k8s.io/component-base/version.buildDate=1970-01-01T00:00:01Z"
    "-X k8s.io/component-base/version.gitCommit=not_available"
    "-X github.com/containerd/containerd/version.Version=${k0sContainerd.version}"
  ];

  postInstall = ''
    installShellCompletion --cmd k0s \
      --bash <($out/bin/k0s completion bash) \
      --zsh <($out/bin/k0s completion zsh) \
      --fish <($out/bin/k0s completion fish)

    wrapProgram $out/bin/k0s \
      --prefix PATH : ${lib.makeBinPath runtimeDeps}
  '';

  # Some tests failed with: failed to locate k0s executable: K0S_PATH environment variable not set: stat /build/source/k0s: no such file or directory
  doCheck = false;

  meta = {
    description = "k0s - The Zero Friction Kubernetes";
    homepage = "https://github.com/k0sproject/k0s";
    license = lib.licenses.asl20;
    maintainers = with lib.maintainers; [
      mrdev023
      twz123
    ];
    platforms = lib.platforms.linux;
    mainProgram = "k0s";
  };
}
