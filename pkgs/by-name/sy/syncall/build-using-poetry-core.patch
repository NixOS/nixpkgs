From 97627ed2f8d9f52d5cf53209b13103104dcf3386 Mon Sep 17 00:00:00 2001
From: Raito Bezarius <masterancpp@gmail.com>
Date: Fri, 15 Sep 2023 22:57:37 +0200
Subject: [PATCH] pyproject: use poetry-core instead of poetry

The PEP517 backend for poetry has been extracted in a separate package
as per https://pypi.org/project/poetry-core/
---
 pyproject.toml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 3f6f013..fabf3d5 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -192,7 +192,7 @@ addopts = ["--ignore-glob=quickstart*", "--doctest-modules"]
 
 # build-system -----------------------------------------------------------------
 [build-system]
-requires = ["poetry>=0.12"]
-build-backend = "poetry.masonry.api"
+requires = ["poetry-core"]
+build-backend = "poetry.core.masonry.api"
 
 # vim: tw=80
-- 
2.42.0

