+static bool IsBinPrefixDisabled(void)
+{
+  enum States { UNDEFINED, DISABLED, ENABLED };
+  static States state = UNDEFINED;
+  if (state == UNDEFINED) {
+    state = cmSystemTools::GetEnvVar("NIXPKGS_CMAKE_DISABLE_BIN_PREFIX") != std::nullopt ? DISABLED : ENABLED;
+  }
+  return state == DISABLED;
+}
