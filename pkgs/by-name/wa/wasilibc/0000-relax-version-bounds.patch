--- a/cmake/wasi-wits.cmake
+++ b/cmake/wasi-wits.cmake
@@ -12,10 +12,6 @@
     OUTPUT_VARIABLE WKG_VERSION
     OUTPUT_STRIP_TRAILING_WHITESPACE)
 
