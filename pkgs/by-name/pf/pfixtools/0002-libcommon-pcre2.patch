+    pcre2_match_data *md =
+        pcre2_match_data_create_from_pattern(re->re, NULL);
+    int rc = pcre2_match(re->re, (PCRE2_SPTR)str->str, str->len,
+                         0, 0, md, NULL);
+    pcre2_match_data_free(md);
+    return rc >= 0;
 }
 
 bool regexp_match(const regexp_t *re, const char *str)
