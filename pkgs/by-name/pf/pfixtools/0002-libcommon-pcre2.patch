@@ -89,8 +88,12 @@ bool regexp_compile_str(regexp_t *re, const clstr_t *str, bool cs)
 
 bool regexp_match_str(const regexp_t *re, const clstr_t *str)
 {
-    return 0 == pcre_exec(re->re, re->extra, str->str, str->len,
