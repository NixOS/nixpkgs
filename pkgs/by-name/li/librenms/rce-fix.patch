 resources/definitions/config_definitions.json | 35 ++-----
 .../tabs/ports/includes/port_row.blade.php    |  4 +-
 routes/web.php                                |  1 -
 14 files changed, 13 insertions(+), 207 deletions(-)
 delete mode 100644 app/Http/Controllers/Ajax/NetCommand.php

