 testing/common/lsltypes.hpp |  2 +-
 testing/ext/DataType.cpp    |  2 +-
 testing/ext/sync_outlet.cpp |  2 +-
 testing/ext/time.cpp        |  4 ++--
 14 files changed, 73 insertions(+), 40 deletions(-)

