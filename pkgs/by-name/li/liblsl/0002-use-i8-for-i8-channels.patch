 include/lsl/outlet.h        | 16 +++++++-------
 include/lsl_cpp.h           | 43 ++++++++++++++++++++++++++++++++-----
 src/data_receiver.cpp       |  2 +-
 src/lsl_inlet_c.cpp         |  4 ++--
 src/lsl_outlet_c.cpp        | 16 +++++++-------
 src/sample.cpp              |  4 ++--
