Stop pnpm 10.21+ from auto-downloading its own bun and node binaries
via engines.runtime.

With `"onFail": "download"`, pnpm injects them as managed runtime:
dependencies and the resulting platform-specific binaries break inside
the Nix build sandbox. Removing the onFail field makes pnpm skip the
injection. The matching runtime: entries are also dropped from
pnpm-lock.yaml so --frozen-lockfile stays consistent.

This makes pnpmDeps platform-independent so a single hash suffices
across systems.

--- a/package.json
+++ b/package.json
@@ -13,12 +13,10 @@
 			{
 				"name": "node",
-				"version": "^24.13.0",
-				"onFail": "download"
+				"version": "^24.13.0"
 			},
 			{
 				"name": "bun",
-				"version": "^1.3.9",
-				"onFail": "download"
+				"version": "^1.3.9"
 			}
 		]
 	},
--- a/pnpm-lock.yaml
+++ b/pnpm-lock.yaml
@@ -182,13 +182,6 @@
 importers:

   .:
-    dependencies:
-      bun:
-        specifier: runtime:^1.3.9
-        version: runtime:1.3.9
-      node:
-        specifier: runtime:^24.13.0
-        version: runtime:24.13.1
