From f37ad718fc0c04a08613e4dfc1baeb1a10848322 Mon Sep 17 00:00:00 2001
From: Freya Murphy <freya@freyacat.org>
Date: Thu, 17 Jul 2025 12:58:56 -0400
Subject: [PATCH] fix source

---
 src/background.js      | 3 ++-
 src/store/localData.js | 2 +-
 vue.config.js          | 6 ++----
 3 files changed, 5 insertions(+), 6 deletions(-)

diff --git a/src/background.js b/src/background.js
index 426a84a..3b587ab 100644
--- a/src/background.js
+++ b/src/background.js
@@ -747,7 +747,8 @@ async function createWindow () {
     titleBarStyle: 'hidden',
     autoHideMenuBar: true,
     webPreferences: {
-      nodeIntegration: process.env.ELECTRON_NODE_INTEGRATION,
+      nodeIntegration: true,
+      contextIsolation: false,
       enableRemoteModule: true,
       plugins: true,
       webviewTag: true
diff --git a/src/store/localData.js b/src/store/localData.js
index 2be2235..69833ff 100644
--- a/src/store/localData.js
+++ b/src/store/localData.js
@@ -33,7 +33,7 @@ const migrations = {
   '2.6.9': store => {
     const settings_prev = store.get('settings', {})
     if (settings_prev && !isWebApp && settings_prev.ruffleFallback) {
-      store.set('settings.ruffleFallback', false)
+      store.set('settings.ruffleFallback', true)
     }
   }
 }
diff --git a/vue.config.js b/vue.config.js
index 04b61d3..03cb6ad 100644
--- a/vue.config.js
+++ b/vue.config.js
@@ -1,7 +1,7 @@
 const webpack = require('webpack')
 const { execSync } = require('child_process')
 
-const git_branch = execSync('git rev-parse --abbrev-ref HEAD').toString()
+const git_branch = "main"
 
 var build_info = {
   'process.env.BUILD_BRANCH': JSON.stringify(
@@ -9,9 +9,7 @@ var build_info = {
   ),
   'process.env.BUILD_DATE': JSON.stringify(new Date().toISOString()),
   'process.env.BUILD_PLATFORM': JSON.stringify(process.platform),
-  'process.env.BUILD_GIT_REVISION': JSON.stringify(
-    execSync('git rev-parse HEAD').toString().trim()
-  )
+  'process.env.BUILD_GIT_REVISION': "NIX_GIT_REVISION"
 }
 
 try {
