-	include(${CMAKE_CURRENT_SOURCE_DIR}/cmake/CPM.cmake)
-endif ()
-
 if(CROW_GENERATE_SBOM)
   CPMAddPackage(
     NAME cmake-sbom
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
