+    break;
+  case 4: /* RGBA */
+    clr.Set(pixel[0] / div, pixel[1] / div, pixel[2] / div, pixel[3] / div);
+    break;
+  default:
+    gzerr << "Image: Unsupported number of channels [" << channels << "] \n";
