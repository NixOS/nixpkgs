From 6e91d48fdaf50587530047dffed9f1fe63ebb9bb Mon Sep 17 00:00:00 2001
From: Francesco Zanini <francesco@zanini.me>
Date: Mon, 6 Oct 2025 16:19:55 +0200
Subject: [PATCH] Hardcode full path to resources and modules

The generated config file from upstream contains a path to the modules
and resources directories. In Nix, this is a location that is fixed, yet
changing every time the derivation changes.

This commit removes the ability to set those paths from the config file
and hard-codes them to the correct values.
---
 core/src/config.cpp | 15 ++++++++++++++-
 core/src/config.h   |  3 ++-
 core/src/core.cpp   | 15 ++-------------
 3 files changed, 18 insertions(+), 15 deletions(-)

diff --git a/core/src/config.cpp b/core/src/config.cpp
index 6de1888fd803d4bbe04c7a4ed2187103dd8a5081..8759e97c4b16670b6863f554a6cea34b12e5738f 100644
--- a/core/src/config.cpp
+++ b/core/src/config.cpp
@@ -41,9 +41,22 @@ void ConfigManager::load(json def, bool lock) {
         conf = def;
         save(false);
     }
+
+    this->postprocess(conf);
+
     if (lock) { mtx.unlock(); }
 }
 
+void ConfigManager::postprocess(json& conf) {
+    std::string suffix = "/config.json";
+    if (this->path.compare(this->path.size() - suffix.size(), suffix.size(), suffix) != 0) {
+        return;
+    }
+
+    conf["modulesDirectory"] = INSTALL_PREFIX "/lib/sdrpp/plugins";
+    conf["resourcesDirectory"] = INSTALL_PREFIX "/share/sdrpp";
+}
+
 void ConfigManager::save(bool lock) {
     if (lock) { mtx.lock(); }
     std::ofstream file(path.c_str());
@@ -98,4 +111,4 @@ void ConfigManager::autoSaveWorker() {
             termCond.wait_for(lock, std::chrono::milliseconds(1000), [this]() { return termFlag; });
         }
     }
-}
\ No newline at end of file
+}
diff --git a/core/src/config.h b/core/src/config.h
index fbbdeb4a54e06524a399e35afe8e187732bf851e..312ea0e15d6e62a21a1e82dcefad38192edc9abc 100644
--- a/core/src/config.h
+++ b/core/src/config.h
@@ -23,6 +23,7 @@ class ConfigManager {
 
 private:
     void autoSaveWorker();
+    void postprocess(json& conf);
 
     std::string path = "";
     volatile bool changed = false;
@@ -33,4 +34,4 @@ class ConfigManager {
     std::mutex termMtx;
     std::condition_variable termCond;
     volatile bool termFlag = false;
-};
\ No newline at end of file
+};
diff --git a/core/src/core.cpp b/core/src/core.cpp
index 37358062ed957e562bf971fa121d885073f2827c..f1b5396cad3154546bb3a2322403b7f3618ad253 100644
--- a/core/src/core.cpp
+++ b/core/src/core.cpp
@@ -267,19 +267,8 @@ int sdrpp_main(int argc, char* argv[]) {
     defConfig["lockMenuOrder"] = false;
 #endif
 
-#if defined(_WIN32)
-    defConfig["modulesDirectory"] = "./modules";
-    defConfig["resourcesDirectory"] = "./res";
-#elif defined(IS_MACOS_BUNDLE)
-    defConfig["modulesDirectory"] = "../Plugins";
-    defConfig["resourcesDirectory"] = "../Resources";
-#elif defined(__ANDROID__)
-    defConfig["modulesDirectory"] = root + "/modules";
-    defConfig["resourcesDirectory"] = root + "/res";
-#else
-    defConfig["modulesDirectory"] = INSTALL_PREFIX "/lib/sdrpp/plugins";
-    defConfig["resourcesDirectory"] = INSTALL_PREFIX "/share/sdrpp";
-#endif
+    defConfig["modulesDirectory"] = "@prefix@/lib/sdrpp/plugins";
+    defConfig["resourcesDirectory"] = "@prefix@/share/sdrpp";
 
     // Load config
     flog::info("Loading config");

