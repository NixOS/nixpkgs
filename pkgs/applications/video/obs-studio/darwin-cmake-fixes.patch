diff --git a/libobs-metal/CMakeLists.txt b/libobs-metal/CMakeLists.txt
index c844044..404f731 100644
--- a/libobs-metal/CMakeLists.txt
+++ b/libobs-metal/CMakeLists.txt
@@ -41,6 +41,19 @@ target_sources(
 
 target_link_libraries(libobs-metal PRIVATE OBS::libobs)
 
+target_compile_options(
+  libobs-metal
+  PRIVATE
+    "$<$<COMPILE_LANGUAGE:Swift>:SHELL:-import-objc-header ${CMAKE_CURRENT_SOURCE_DIR}/libobs-metal-Bridging-Header.h>"
+    "$<$<COMPILE_LANGUAGE:Swift>:SHELL:-Xcc -fmodules>"
+    "$<$<COMPILE_LANGUAGE:Swift>:SHELL:-Xcc -fcxx-modules>"
+)
+
+set_target_properties(
+  libobs-metal
+  PROPERTIES
+    Swift_LANGUAGE_VERSION 5
+    Swift_MODULE_NAME libobs_metal
+)
+
 target_enable_feature(libobs "Metal renderer")
 
 set_property(SOURCE OBSMetalRenderer.swift APPEND PROPERTY COMPILE_FLAGS -emit-objc-header)
