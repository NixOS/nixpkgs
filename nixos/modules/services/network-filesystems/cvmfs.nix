{
  config,
  lib,
  pkgs,
  ...
}:

let
  cfg = config.services.cvmfs;

  defaultLocalConf = lib.concatStringsSep "\n" (
    [ "# Generated by NixOS" ]
    ++ lib.optional (
      cfg.repositories != [ ]
    ) "CVMFS_REPOSITORIES=${lib.concatStringsSep "," cfg.repositories}"
    ++ lib.optional (cfg.httpProxy != null) "CVMFS_HTTP_PROXY='${cfg.httpProxy}'"
    ++ lib.optional (cfg.quotaLimit != null) "CVMFS_QUOTA_LIMIT=${toString cfg.quotaLimit}"
    ++ lib.optional (cfg.cacheBase != null) "CVMFS_CACHE_BASE=${cfg.cacheBase}"
    ++ lib.optional (cfg.clientProfile != null) "CVMFS_CLIENT_PROFILE=${cfg.clientProfile}"
    ++ lib.mapAttrsToList (k: v: "${k}=${v}") cfg.extraConfig
    ++ [ "" ]
  );

  configDDir = pkgs.runCommand "cvmfs-config-d" { } ''
    mkdir -p $out
    if [ -d "${cfg.package}/etc/cvmfs/config.d" ]; then
      cp -r ${cfg.package}/etc/cvmfs/config.d/* $out/ 2>/dev/null || true
    fi
    ${lib.concatStringsSep "\n" (
      lib.mapAttrsToList (
        repo: content: "cat > $out/${lib.escapeShellArg repo}.local << 'CVMFSEOF'\n${content}\nCVMFSEOF"
      ) cfg.extraRepoConfig
    )}
  '';

  repoMountPoint = repo: "/cvmfs/${repo}";
in
{
  options.services.cvmfs = {
    enable = lib.mkEnableOption "CernVM-FS client with systemd automount";

    package = lib.mkPackageOption pkgs "cvmfs" { };

    repositories = lib.mkOption {
      type = lib.types.listOf lib.types.str;
      default = [ ];
      example = [
        "sft.cern.ch"
        "cms.cern.ch"
        "cvmfs-config.cern.ch"
      ];
      description = ''
        List of CVMFS repository fully-qualified names to automount.
        Each gets a systemd .mount and .automount unit at /cvmfs/<repo>.
      '';
    };

    httpProxy = lib.mkOption {
      type = lib.types.nullOr lib.types.str;
      default = "DIRECT";
      example = "http://squid.example.com:3128";
      description = ''
        HTTP proxy for CVMFS.
        `"DIRECT"` connects to Stratum 1 servers directly,
        `"auto"` uses WPAD for proxy discovery.
        Set to `null` to omit from configuration.
      '';
    };

    quotaLimit = lib.mkOption {
      type = lib.types.nullOr lib.types.int;
      default = 4000;
      description = "Soft limit in MB for the local CVMFS cache.";
    };

    cacheBase = lib.mkOption {
      type = lib.types.nullOr lib.types.str;
      default = "/var/cache/cvmfs";
      description = "Base directory for the CVMFS local cache.";
    };

    clientProfile = lib.mkOption {
      type = lib.types.nullOr (lib.types.enum [ "single" ]);
      default = "single";
      description = ''
        Client profile. `"single"` is appropriate for laptops and small setups
        (enables WPAD proxy discovery). Set to `null` for cluster deployments.
      '';
    };

    extraConfig = lib.mkOption {
      type = lib.types.attrsOf lib.types.str;
      default = { };
      example = {
        CVMFS_TIMEOUT = "10";
        CVMFS_NFILES = "65536";
      };
      description = "Additional key-value pairs appended to `default.local`.";
    };

    extraRepoConfig = lib.mkOption {
      type = lib.types.attrsOf lib.types.str;
      default = { };
      example = {
        "atlas.cern.ch" = "CVMFS_QUOTA_LIMIT=8000";
      };
      description = ''
        Per-repository configuration overrides.
        Keys are repository FQRNs, values are the content for
        `/etc/cvmfs/config.d/<repo>.local`.
      '';
    };

    automountIdleTimeout = lib.mkOption {
      type = lib.types.str;
      default = "600";
      description = ''
        Seconds of inactivity after which systemd unmounts the CVMFS
        filesystem. Set to `"0"` to keep it mounted indefinitely.
      '';
    };
  };

  config = lib.mkIf cfg.enable {

    environment.systemPackages = [ cfg.package ];

    system.fsPackages = [ cfg.package ];

    boot.kernelModules = [ "fuse" ];

    users.groups.cvmfs = { };
    users.users.cvmfs = {
      isSystemUser = true;
      group = "cvmfs";
      description = "CernVM-FS service user";
    };

    programs.fuse.userAllowOther = true;

    environment.etc = {
      "cvmfs/default.conf".source = "${cfg.package}/etc/cvmfs/default.conf";
      "cvmfs/default.d".source = "${cfg.package}/etc/cvmfs/default.d";
      "cvmfs/domain.d".source = "${cfg.package}/etc/cvmfs/domain.d";
      "cvmfs/config.d".source = configDDir;
      "cvmfs/keys".source = "${cfg.package}/etc/cvmfs/keys";
      "cvmfs/default.local".text = defaultLocalConf;
    };

    systemd.tmpfiles.rules = [
      "d ${cfg.cacheBase} 0755 cvmfs cvmfs -"
      "d /cvmfs 0755 root root -"
    ]
    ++ map (repo: "d ${repoMountPoint repo} 0755 root root -") cfg.repositories;

    systemd.mounts = map (repo: {
      what = repo;
      where = repoMountPoint repo;
      type = "fuse.cvmfs2";
      options = lib.concatStringsSep "," [
        "allow_other"
        "grab_mountpoint"
      ];
      wantedBy = [ ];
      requires = [ "network-online.target" ];
      after = [ "network-online.target" ];
      mountConfig = {
        TimeoutSec = "60";
        LazyUnmount = true;
      };
    }) cfg.repositories;

    systemd.automounts = map (repo: {
      where = repoMountPoint repo;
      wantedBy = [ "remote-fs.target" ];
      automountConfig = {
        TimeoutIdleSec = cfg.automountIdleTimeout;
      };
    }) cfg.repositories;
  };
}
