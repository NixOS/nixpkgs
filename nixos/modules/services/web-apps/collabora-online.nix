{
  config,
  lib,
  pkgs,
  utils,
  ...
}:

let
  cfg = config.services.collabora-online;

  configFile =
    let
      c = cfg.config;
      toStr =
        x:
        if x == null then
          ""
        else if lib.isBool x then
          lib.boolToString x
        else if lib.isInt x || lib.isFloat x then
          toString x
        else if lib.isString x then
          lib.escapeXML x
        else
          throw "Unsupported type: ${builtins.toJSON x}";
    in
    # Example config file is taken from https://github.com/CollaboraOnline/online/blob/master/coolwsd.xml.in
    pkgs.writeText "coolwsd.xml" ''
      <config>

          <!-- For more detailed documentation on typical configuration options please see:
               https://sdk.collaboraonline.com/docs/installation/Configuration.html -->

          <!-- Note: 'default' attributes are used to document a setting's default value as well as to use as fallback. -->
          <!-- Note: When adding a new entry, a default must be set in WSD in case the entry is missing upon deployment. -->

          <accessibility desc="Accessibility settings">
              <enable type="bool" desc="Controls whether accessibility support should be enabled or not." default="false">${toStr c.accessibility.enable}</enable>
          </accessibility>

          <allowed_languages desc="List of supported languages of Writing Aids (spell checker, grammar checker, thesaurus, hyphenation) on this instance. Allowing too many has negative effect on startup performance." default="de_DE en_GB en_US es_ES fr_FR it nl pt_BR pt_PT ru">${lib.escapeXML (lib.concatStringsSep " " c.allowed_languages)}</allowed_languages>

          <!--
              These are the settings of external (remote) spellchecker and grammar checker services. Currently LanguageTool and Duden Korrekturserver APIs are supported, you can
              set either of them. By default they are disabled. To turn the support on, please set "enabled" property to true. It works with self hosted or cloud services, free
              and premium as well. The "base_url" may be https://api.languagetoolplus.com/v2 if the cloud version of LanguageTool is used. Please note that your data in the
              document e.g. the text part of it will be sent to the cloud API. Please read the respective privacy policies, e.g. https://languagetool.org/legal/privacy.
          -->
          <languagetool desc="Remote API settings for spell and grammar checking">
              <enabled desc="Enable Remote Spell and Grammar Checker" type="bool" default="false">${toStr c.languagetool.enabled}</enabled>
              <base_url desc="HTTP endpoint for the API server, without /check or /languages postfix at the end." type="string" default="">${toStr c.languagetool.base_url}</base_url>
              <user_name desc="LanguageTool or Duden account username for premium usage." type="string" default="">${toStr c.languagetool.user_name}</user_name>
              <api_key desc="API key provided by LanguageTool or Duden account for premium usage." type="string" default="">${toStr c.languagetool.api_key}</api_key>
              <ssl_verification desc="Enable or disable SSL verification. You may have to disable it in test environments with self-signed certificates." type="string" default="true">${toStr c.languagetool.ssl_verification}</ssl_verification>
              <rest_protocol desc="REST API protocol. For LanguageTool leave it blank, for Duden Korrekturserver use the string 'duden'." type="string" default="">${toStr c.languagetool.rest_protocol}</rest_protocol>
          </languagetool>

          <deepl desc="DeepL API settings for translation service">
              <enabled desc="If true, shows translate option as a menu entry in the compact view and as an icon in the tabbed view." type="bool" default="false">${toStr c.deepl.enabled}</enabled>
              <api_url desc="URL for the API" type="string" default="">${toStr c.deepl.api_url}</api_url>
              <auth_key desc="Auth Key generated by your account" type="string" default="">${toStr c.deepl.auth_key}</auth_key>
          </deepl>

          <sys_template_path desc="Path to a template tree with shared libraries etc to be used as source for chroot jails for child processes." type="path" relative="true" default="systemplate">/var/lib/cool/systemplate</sys_template_path>
          <child_root_path desc="Path to the directory under which the chroot jails for the child processes will be created. Should be on the same file system as systemplate and lotemplate. Must be an empty directory." type="path" relative="true" default="jails">/var/lib/cool/child-roots</child_root_path>
          <mount_jail_tree desc="Controls whether the systemplate and lotemplate contents are mounted or not, which is much faster than the default of linking/copying each file." type="bool" default="true">${toStr c.mount_jail_tree}</mount_jail_tree>
          <mount_namespaces desc="Use mount namespaces instead of coolmount." type="bool" default="false">${toStr c.mount_namespaces}</mount_namespaces>

          <server_name desc="External hostname:port of the server running coolwsd. If empty, it's derived from the request (please set it if this doesn't work). May be specified when behind a reverse-proxy or when the hostname is not reachable directly." type="string" default="">${toStr c.server_name}</server_name>
          <file_server_root_path desc="Path to the directory that should be considered root for the file server. This should be the directory containing cool." type="path" relative="true" default="browser/../">../share/coolwsd</file_server_root_path>
          <hexify_embedded_urls desc="Enable to protect encoded URLs from getting decoded by intermediate hops. Particularly useful on Azure deployments" type="bool" default="false">${toStr c.hexify_embedded_urls}</hexify_embedded_urls>
          <experimental_features desc="Enable/Disable experimental features" type="bool" default="false">${toStr c.experimental_features}</experimental_features>

          <memproportion desc="The maximum percentage of available memory consumed by all of the Collabora Online Development Edition processes, after which we start cleaning up idle documents. If cgroup memory limits are set, this is the maximum percentage of that limit to consume." type="double" default="80.0">${toStr c.memproportion}</memproportion>
          <num_prespawn_children desc="Number of child processes to keep started in advance and waiting for new clients." type="uint" default="4">${toStr c.num_prespawn_children}</num_prespawn_children>
          <!-- <fetch_update_check desc="Every number of hours will fetch latest version data. Defaults to 10 hours." type="uint" default="10">10</fetch_update_check> -->
          <!-- <allow_update_popup desc="Allows notification about an update in the editor" type="bool" default="true">true</allow_update_popup> -->
          <per_document desc="Document-specific settings, including LO Core settings.">
              <max_concurrency desc="The maximum number of threads to use while processing a document." type="uint" default="4">${toStr c.per_document.max_concurrency}</max_concurrency>
              <batch_priority desc="A (lower) priority for use by batch eg. convert-to processes to avoid starving interactive ones" type="uint" default="5">${toStr c.per_document.batch_priority}</batch_priority>
              <bgsave_priority desc="A (lower) priority for use by background save processes to free time for interactive ones" type="uint" default="5">${toStr c.per_document.bgsave_priority}</bgsave_priority>
              <redlining_as_comments desc="If true show red-lines as comments" type="bool" default="false">${toStr c.per_document.redlining_as_comments}</redlining_as_comments>
              <pdf_resolution_dpi desc="The resolution, in DPI, used to render PDF documents as image. Memory consumption grows proportionally. Must be a positive value less than 385. Defaults to 96." type="uint" default="96">${toStr c.per_document.pdf_resolution_dpi}</pdf_resolution_dpi>
              <idle_timeout_secs desc="The maximum number of seconds before unloading an idle document. Defaults to 1 hour." type="uint" default="3600">${toStr c.per_document.idle_timeout_secs}</idle_timeout_secs>
              <idlesave_duration_secs desc="The number of idle seconds after which document, if modified, should be saved. Disabled when 0. Defaults to 30 seconds." type="uint" default="30">${toStr c.per_document.idlesave_duration_secs}</idlesave_duration_secs>
              <autosave_duration_secs desc="The number of seconds after which document, if modified, should be saved. Disabled when 0. Defaults to 5 minutes." type="uint" default="300">${toStr c.per_document.autosave_duration_secs}</autosave_duration_secs>
              <background_autosave desc="Allow auto-saves to occur in a forked background process where possible." type="bool" default="true">${toStr c.per_document.background_autosave}</background_autosave>
              <background_manualsave desc="Allow manual save to occur in a forked background process where possible" type="bool" default="true">${toStr c.per_document.background_manualsave}</background_manualsave>
              <always_save_on_exit desc="On exiting the last editor, always perform a save and upload if the document had been modified. This is to allow the storage to store the document, if it had skipped doing so, previously, as an optimization." type="bool" default="false">${toStr c.per_document.always_save_on_exit}</always_save_on_exit>
              <limit_virt_mem_mb desc="The maximum virtual memory allowed to each document process. 0 for unlimited." type="uint">${toStr c.per_document.limit_virt_mem_mb}</limit_virt_mem_mb>
              <limit_stack_mem_kb desc="The maximum stack size allowed to each document process. 0 for unlimited." type="uint">${toStr c.per_document.limit_stack_mem_kb}</limit_stack_mem_kb>
              <limit_file_size_mb desc="The maximum file size allowed to each document process to write. 0 for unlimited." type="uint">${toStr c.per_document.limit_file_size_mb}</limit_file_size_mb>
              <limit_num_open_files desc="The maximum number of files allowed to each document process to open. 0 for unlimited." type="uint">${toStr c.per_document.limit_num_open_files}</limit_num_open_files>
              <limit_load_secs desc="Maximum number of seconds to wait for a document load to succeed. 0 for unlimited." type="uint" default="100">${toStr c.per_document.limit_load_secs}</limit_load_secs>
              <limit_store_failures desc="Maximum number of consecutive save-and-upload to storage failures when unloading the document. 0 for unlimited (not recommended)." type="uint" default="5">${toStr c.per_document.limit_store_failures}</limit_store_failures>
              <limit_convert_secs desc="Maximum number of seconds to wait for a document conversion to succeed. 0 for unlimited." type="uint" default="100">${toStr c.per_document.limit_convert_secs}</limit_convert_secs>
              <min_time_between_saves_ms desc="Minimum number of milliseconds between saving the document on disk." type="uint" default="500">${toStr c.per_document.min_time_between_saves_ms}</min_time_between_saves_ms>
              <min_time_between_uploads_ms desc="Minimum number of milliseconds between uploading the document to storage." type="uint" default="5000">${toStr c.per_document.min_time_between_uploads_ms}</min_time_between_uploads_ms>
              <cleanup desc="Checks for resource consuming (bad) documents and kills associated kit process. A document is considered resource consuming (bad) if is in idle state for idle_time_secs period and memory usage passed limit_dirty_mem_mb or CPU usage passed limit_cpu_per" enable="${toStr c.per_document.cleanup.enable}">
                  <cleanup_interval_ms desc="Interval between two checks" type="uint" default="10000">${toStr c.per_document.cleanup.cleanup_interval_ms}</cleanup_interval_ms>
                  <bad_behavior_period_secs desc="Minimum time period for a document to be in bad state before associated kit process is killed. If in this period the condition for bad document is not met once then this period is reset" type="uint" default="60">${toStr c.per_document.cleanup.bad_behavior_period_secs}</bad_behavior_period_secs>
                  <idle_time_secs desc="Minimum idle time for a document to be candidate for bad state" type="uint" default="300">${toStr c.per_document.cleanup.idle_time_secs}</idle_time_secs>
                  <limit_dirty_mem_mb desc="Minimum memory usage for a document to be candidate for bad state" type="uint" default="3072">${toStr c.per_document.cleanup.limit_dirty_mem_mb}</limit_dirty_mem_mb>
                  <limit_cpu_per desc="Minimum CPU usage for a document to be candidate for bad state" type="uint" default="85">${toStr c.per_document.cleanup.limit_cpu_per}</limit_cpu_per>
                  <lost_kit_grace_period_secs desc="The minimum grace period for a lost kit process (not referenced by coolwsd) to resolve its lost status before it is terminated. To disable the cleanup of lost kits use value 0" default="120">${toStr c.per_document.cleanup.lost_kit_grace_period_secs}</lost_kit_grace_period_secs>
              </cleanup>
          </per_document>

          <per_view desc="View-specific settings.">
              <out_of_focus_timeout_secs desc="The maximum number of seconds before dimming and stopping updates when the browser tab is no longer in focus. Defaults to 300 seconds." type="uint" default="300">${toStr c.per_view.out_of_focus_timeout_secs}</out_of_focus_timeout_secs>
              <idle_timeout_secs desc="The maximum number of seconds before dimming and stopping updates when the user is no longer active (even if the browser is in focus). Defaults to 15 minutes." type="uint" default="900">${toStr c.per_view.idle_timeout_secs}</idle_timeout_secs>
              <custom_os_info desc="Custom string shown as OS version in About dialog, get from system if empty." type="string" default="">${toStr c.per_view.custom_os_info}</custom_os_info>
          </per_view>

          <ver_suffix desc="Appended to etags to allow easy refresh of changed files during development" type="string" default="">${toStr c.ver_suffix}</ver_suffix>

          <logging>
              <color type="bool">${toStr c.logging.color}</color>
              <!--
                   Note to developers: When you do "make run", the logging.level will be set on the
                   coolwsd command line, so if you want to change it for your testing, do it in
                   Makefile.am, not here.
              -->
              <level type="string" desc="Can be 0-8 (with the lowest numbers being the least verbose), or none (turns off logging), fatal, critical, error, warning, notice, information, debug, trace" default="warning">${toStr c.logging.level}</level>
              <level_startup type="string" desc="As for level - but for the initial startup phase which is most problematic, logging reverts to level configured above when startup is complete" default="trace">${toStr c.logging.level_startup}</level_startup>
              <disabled_areas type="string" desc="High verbosity logging ie. info to trace are disable-able, comma separated: Generic, Pixel, Socket, WebSocket, Http, WebServer, Storage, WOPI, Admin, Javascript" default="Socket,WebSocket,Admin">${lib.escapeXML (lib.concatStringsSep "," c.logging.disabled_areas)}</disabled_areas>
              <most_verbose_level_settable_from_client type="string" desc="A loggingleveloverride message from the client can not set a more verbose log level than this" default="notice">${toStr c.logging.most_verbose_level_settable_from_client}</most_verbose_level_settable_from_client>
              <least_verbose_level_settable_from_client type="string" desc="A loggingleveloverride message from a client can not set a less verbose log level than this" default="fatal">${toStr c.logging.least_verbose_level_settable_from_client}</least_verbose_level_settable_from_client>
              <protocol type="bool" desc="Enable minimal client-site JS protocol logging from the start">${toStr c.logging.protocol}</protocol>
              <!-- lokit_sal_log example: Log WebDAV-related messages, that is interesting for debugging Insert - Image operation: "+TIMESTAMP+INFO.ucb.ucp.webdav+WARN.ucb.ucp.webdav"
                   See also: https://docs.libreoffice.org/sal/html/sal_log.html -->
              <lokit_sal_log type="string" desc="Fine tune log messages from LOKit. Default is to suppress log messages from LOKit." default="-INFO-WARN">${toStr c.logging.lokit_sal_log}</lokit_sal_log>
              <file enable="${toStr c.logging.file.enable}">
                  <!-- If you use other path than /var/log and you run coolwsd from systemd, make sure that you enable that path in coolwsd.service (ReadWritePaths). -->
                  <property name="path" desc="Log file path.">${toStr c.logging.file.path}</property>
                  <property name="rotation" desc="Log file rotation strategy. See Poco FileChannel.">${toStr c.logging.file.rotation}</property>
                  <property name="archive" desc="Append either timestamp or number to the archived log filename.">${toStr c.logging.file.archive}</property>
                  <property name="compress" desc="Enable/disable log file compression.">${toStr c.logging.file.compress}</property>
                  <property name="purgeAge" desc="The maximum age of log files to preserve. See Poco FileChannel.">${toStr c.logging.file.purgeAge}</property>
                  <property name="purgeCount" desc="The maximum number of log archives to preserve. Use 'none' to disable purging. See Poco FileChannel.">${toStr c.logging.file.purgeCount}</property>
                  <property name="rotateOnOpen" desc="Enable/disable log file rotation on opening.">${toStr c.logging.file.rotateOnOpen}</property>
                  <property name="flush" desc="Enable/disable flushing after logging each line. May harm performance. Note that without flushing after each line, the log lines from the different processes will not appear in chronological order.">${toStr c.logging.file.flush}</property>
              </file>
              <anonymize>
                  <anonymize_user_data type="bool" desc="Enable to anonymize/obfuscate of user-data in logs. If default is true, it was forced at compile-time and cannot be disabled." default="false">${toStr c.logging.anonymize.anonymize_user_data}</anonymize_user_data>
                  <anonymization_salt type="uint" desc="The salt used to anonymize/obfuscate user-data in logs. Use a secret 64-bit random number." default="82589933">${toStr c.logging.anonymize.anonymization_salt}</anonymization_salt>
              </anonymize>
              <docstats type="bool" desc="Enable to see document handling information in logs." default="false">${toStr c.logging.docstats}</docstats>
              <userstats desc="Enable user stats. i.e: logs the details of a file and user" type="bool" default="false">${toStr c.logging.userstats}</userstats>
              <disable_server_audit type="bool" desc="Disabled server audit dialog and notification. Admin will no longer see warnings in the application user interface. This doesn't affect log file." default="false">${toStr c.logging.disable_server_audit}</disable_server_audit>
          </logging>

          <!--
               Note to developers: When you do "make run", the trace_event[@enable] will be set on the
               coolwsd command line, so if you want to change it for your testing, do it in Makefile.am,
               not here.
          -->
          <trace_event desc="The possibility to turn on generation of a Chrome Trace Event file" enable="${toStr c.trace_event.enable}">
              <path desc="Output path for the Trace Event file, to which they will be written if turned on at run-time" type="string" default="/var/log/coolwsd.trace.json">${toStr c.trace_event.path}</path>
          </trace_event>

          <browser_logging desc="Logging in the browser console" default="false">${toStr c.browser_logging}</browser_logging>

          <trace desc="Dump commands and notifications for replay. When 'snapshot' is true, the source file is copied to the path first." enable="${toStr c.trace.enable}">
              <path desc="Output path to hold trace file and docs. Use '%' for timestamp to avoid overwriting. For example: /some/path/to/cooltrace-%.gz" compress="${toStr c.trace.path.compress}" snapshot="${toStr c.trace.path.snapshot}">${lib.optionalString c.trace.enable (toStr c.trace.path.path)}</path>
              <filter>
                  <!-- <message desc="Regex pattern of messages to exclude"></message> -->
                  ${lib.concatLines (map (message: "<message>${toStr message}</message>") c.trace.filter)}
              </filter>
              <outgoing>
                  <record desc="Whether or not to record outgoing messages" default="false">${toStr c.trace.outgoing.record}</record>
              </outgoing>
          </trace>

          <net desc="Network settings">
            <!-- On systems where localhost resolves to IPv6 [::1] address first, when net.proto is all and net.listen is loopback, coolwsd unexpectedly listens on [::1] only.
                 You need to change net.proto to IPv4, if you want to use 127.0.0.1. -->
            <proto type="string" default="all" desc="Protocol to use IPv4, IPv6 or all for both">${toStr c.net.proto}</proto>
            <listen type="string" default="any" desc="Listen address that coolwsd binds to. Can be 'any' or 'loopback'.">${toStr c.net.listen}</listen>
            <!-- this allows you to shift all of our URLs into a sub-path from
                 https://my.com/browser/a123... to https://my.com/my/sub/path/browser/a123... -->
            <service_root type="path" default="" desc="Prefix all the pages, websockets, etc. with this path.">${toStr c.net.service_root}</service_root>
            <post_allow desc="Allow/deny client IP address for POST(REST)." allow="${toStr c.net.post_allow.allow}">
              ${lib.concatLines (map (host: "<host>${host}</host>") c.net.post_allow.hosts)}
            </post_allow>
            <lok_allow desc="Allowed hosts as an external data source inside edited files. All allowed post_allow.host and storage.wopi entries are also considered to be allowed as a data source. Used for example in: PostMessage Action_InsertGraphics, =WEBSERVICE() function, external reference in the cell.">
              ${lib.concatLines (map (host: "<host>${host}</host>") c.net.lok_allow)}
            </lok_allow>
            <content_security_policy desc="Customize the CSP header by specifying one or more policy-directive, separated by semicolons. See w3.org/TR/CSP2">${lib.escapeXML (lib.concatStringsSep ";" c.net.content_security_policy)}</content_security_policy>
            <frame_ancestors desc="OBSOLETE: Use content_security_policy. Specify who is allowed to embed the Collabora Online iframe (coolwsd and WOPI host are always allowed). Separate multiple hosts by space."></frame_ancestors>
            <connection_timeout_secs desc="Specifies the connection, send, recv timeout in seconds for connections initiated by coolwsd (such as WOPI connections)." type="int" default="30">${toStr c.net.connection_timeout_secs}</connection_timeout_secs>

            <!-- this setting radically changes how online works, it should not be used in a production environment -->
            <proxy_prefix type="bool" default="false" desc="Enable a ProxyPrefix to be passed int through which to redirect requests">${toStr c.net.proxy_prefix}</proxy_prefix>
          </net>

          <ssl desc="SSL settings">
              <!-- switches from https:// + wss:// to http:// + ws:// -->
              <enable type="bool" desc="Controls whether SSL encryption between coolwsd and the network is enabled (do not disable for production deployment). If default is false, must first be compiled with SSL support to enable." default="true">${toStr c.ssl.enable}</enable>
              <!-- SSL off-load can be done in a proxy, if so disable SSL, and enable termination below in production -->
              <termination desc="Connection via proxy where coolwsd acts as working via https, but actually uses http." type="bool" default="true">${toStr c.ssl.termination}</termination>
              <cert_file_path desc="Path to the cert file" relative="false">${toStr c.ssl.cert_file_path}</cert_file_path>
              <key_file_path desc="Path to the key file" relative="false">${toStr c.ssl.key_file_path}</key_file_path>
              <ca_file_path desc="Path to the ca file" relative="false">${toStr c.ssl.ca_file_path}</ca_file_path>
              <ssl_verification desc="Enable or disable SSL verification of hosts remote to coolwsd. If true SSL verification will be strict, otherwise certs of hosts will not be verified. You may have to disable it in test environments with self-signed certificates." type="string" default="true">${toStr c.ssl.ssl_verification}</ssl_verification>
              <cipher_list desc="List of OpenSSL ciphers to accept" default="ALL:!ADH:!LOW:!EXP:!MD5:@STRENGTH">${toStr c.ssl.cipher_list}</cipher_list>
              <hpkp desc="Enable HTTP Public key pinning" enable="${toStr c.ssl.hpkp.enable}" report_only="${toStr c.ssl.hpkp.report_only}">
                  <max_age desc="HPKP's max-age directive - time in seconds browser should remember the pins" enable="${
                    toStr (c.ssl.hpkp.max_age != null)
                  }">${toStr c.ssl.hpkp.max_age}</max_age>
                  <report_uri desc="HPKP's report-uri directive - pin validation failure are reported at this URL" enable="${
                    toStr (c.ssl.hpkp.report_uri != null)
                  }">${toStr c.ssl.hpkp.report_uri}</report_uri>
                  <pins desc="Base64 encoded SPKI fingerprints of keys to be pinned">
                    ${lib.concatLines (map (pin: "<pin>${toStr pin}</pin>") c.ssl.hpkp.pins)}
                  </pins>
              </hpkp>
              <sts desc="Strict-Transport-Security settings, per rfc6797. Subdomains are always included.">
                  <enabled desc="Whether or not Strict-Transport-Security is enabled. Enable only when ready for production. Cannot be disabled without resetting the browsers." type="bool" default="false">${toStr c.ssl.sts.enabled}</enabled>
                  <max_age desc="Strict-Transport-Security max-age directive, in seconds. 0 is allowed; please see rfc6797 for details. Defaults to 1 year." type="int" default="31536000">${toStr c.ssl.sts.max_age}</max_age>
              </sts>
          </ssl>

          <security desc="Altering these defaults potentially opens you to significant risk">
            <seccomp desc="Should we use the seccomp system call filtering." type="bool" default="true">${toStr c.security.seccomp}</seccomp>
            <capabilities desc="Should we require capabilities to isolate processes into chroot jails" type="bool" default="true">${toStr c.security.capabilities}</capabilities>
            <jwt_expiry_secs desc="Time in seconds before the Admin Console's JWT token expires" type="int" default="1800">${toStr c.security.jwt_expiry_secs}</jwt_expiry_secs>
            <enable_macros_execution desc="Specifies whether the macro execution is enabled in general. This will enable Basic and Python scripts to execute both installed and from documents. If it is set to false, the macro_security_level is ignored. If it is set to true, the mentioned entry specified the level of macro security." type="bool" default="false">${toStr c.security.enable_macros_execution}</enable_macros_execution>
            <macro_security_level desc="Level of Macro security. 1 (Medium) Confirmation required before executing macros from untrusted sources. 0 (Low, not recommended) All macros will be executed without confirmation." type="int" default="1">${toStr c.security.macro_security_level}</macro_security_level>
            <enable_websocket_urp desc="Should we enable URP (UNO remote protocol) communication over the websocket. This allows full control of the Kit child server to anyone with access to the websocket including executing macros without confirmation or running arbitrary shell commands in the jail." type="bool" default="false">${toStr c.security.enable_websocket_urp}</enable_websocket_urp>
            <enable_metrics_unauthenticated desc="When enabled, the /cool/getMetrics endpoint will not require authentication." type="bool" default="false">${toStr c.security.enable_metrics_unauthenticated}</enable_metrics_unauthenticated>
          </security>

          <certificates>
            <database_path type="string" desc="Path to the NSS certificates that are used for signing documents" default="">${toStr c.certificates.database_path}</database_path>
          </certificates>

          <watermark>
            <opacity desc="Opacity of on-screen watermark from 0.0 to 1.0" type="double" default="0.2">${toStr c.watermark.opacity}</opacity>
            <text desc="Watermark text to be displayed on the document if entered" type="string">${toStr c.watermark.text}</text>
          </watermark>

          <welcome>
            <enable type="bool" desc="Controls whether the welcome screen should be shown to the users on new install and updates." default="false">${toStr c.welcome.enable}</enable>
          </welcome>

          <user_interface>
            <mode type="string" desc="Controls the user interface style. The 'default' means: Take the value from ui_defaults, or decide for one of compact or tabbed (default|compact|tabbed)" default="default">${toStr c.user_interface.mode}</mode>
            <use_integration_theme desc="Use theme from the integrator" type="bool" default="true">${toStr c.user_interface.use_integration_theme}</use_integration_theme>
          </user_interface>

          <storage desc="Backend storage">
              <filesystem allow="${toStr c.storage.filesystem}" />
              <wopi desc="Allow/deny wopi storage." allow="${toStr c.storage.wopi.allow}">
                  <max_file_size desc="Maximum document size in bytes to load. 0 for unlimited." type="uint">${toStr c.storage.wopi.max_file_size}</max_file_size>
                  <locking desc="Locking settings">
                      <refresh desc="How frequently we should re-acquire a lock with the storage server, in seconds (default 15 mins) or 0 for no refresh" type="int" default="900">${toStr c.storage.wopi.locking.refresh}</refresh>
                  </locking>

                  <alias_groups desc="default mode is 'first' it allows only the first host when groups are not defined. set mode to 'groups' and define group to allow multiple host and its aliases" mode="${
                    if c.storage.wopi.alias_groups == null then "first" else "groups"
                  }">
                  <!-- If you need to use multiple wopi hosts, please change the mode to "groups" and
                          add the hosts below.  If one host is accessible under multiple ip addresses
                          or names, add them as aliases. -->
                  <!--<group>
                          <host desc="hostname to allow or deny." allow="true">scheme://hostname:port</host>
                          <alias desc="regex pattern of aliasname">scheme://aliasname1:port</alias>
                          <alias desc="regex pattern of aliasname">scheme://aliasname2:port</alias>
                          @UNLOCK_LINK_PER_HOST@
                  </group>-->
                  ${
                    lib.concatLines (
                      map (group: ''
                        <group>
                            <host desc="hostname to allow or deny." allow="${toStr group.allow}">${toStr group.host}</host>
                            ${
                              lib.concatLines (
                                map (alias: ''<alias desc="regex pattern of aliasname">${toStr alias}</alias>'') group.aliases
                              )
                            }
                            <!-- @UNLOCK_LINK_PER_HOST@ -->
                        </group>
                      '') (lib.optionals (c.storage.wopi.alias_groups != null) c.storage.wopi.alias_groups)
                    )
                  }
                  <!-- More "group"s possible here -->
                  </alias_groups>

                  <is_legacy_server desc="Set to true for legacy server that need deprecated headers." type="bool" default="false">${toStr c.storage.wopi.is_legacy_server}</is_legacy_server>
              </wopi>
              <ssl desc="SSL settings">
                  <as_scheme type="bool" default="true" desc="When set we exclusively use the WOPI URI's scheme to enable SSL for storage">${toStr c.storage.ssl.as_scheme}</as_scheme>
                  <enable type="bool" desc="If as_scheme is false or not set, this can be set to force SSL encryption between storage and coolwsd. When empty this defaults to following the ssl.enable setting">${toStr c.storage.ssl.enable}</enable>
                  <cert_file_path desc="Path to the cert file. When empty this defaults to following the ssl.cert_file_path setting" relative="false">${toStr c.storage.ssl.cert_file_path}</cert_file_path>
                  <key_file_path desc="Path to the key file. When empty this defaults to following the ssl.key_file_path settinge" relative="false">${toStr c.storage.ssl.key_file_path}</key_file_path>
                  <ca_file_path desc="Path to the ca file. When empty this defaults to following the ssl.ca_file_path setting" relative="false">${toStr c.storage.ssl.ca_file_path}</ca_file_path>
                  <cipher_list desc="List of OpenSSL ciphers to accept. If empty the defaults are used. These can be overridden only if absolutely needed.">${toStr c.storage.ssl.cipher_list}</cipher_list>
              </ssl>
          </storage>

          <admin_console desc="Web admin console settings.">
              <enable desc="Enable the admin console functionality" type="bool" default="true">${toStr c.admin_console.enable}</enable>
              <enable_pam desc="Enable admin user authentication with PAM" type="bool" default="false">${toStr c.admin_console.enable_pam}</enable_pam>
              <username desc="The username of the admin console. Ignored if PAM is enabled.">${toStr c.admin_console.username}</username>
              <password desc="The password of the admin console. Deprecated on most platforms. Instead, use PAM or coolconfig to set up a secure password.">${toStr c.admin_console.password}</password>
              <logging desc="Log admin activities irrespective of logging.level">
                  <admin_login desc="log when an admin logged into the console" type="bool" default="true">${toStr c.admin_console.logging.admin_login}</admin_login>
                  <metrics_fetch desc="log when metrics endpoint is accessed and metrics endpoint authentication is enabled" type="bool" default="true">${toStr c.admin_console.logging.metrics_fetch}</metrics_fetch>
                  <monitor_connect desc="log when external monitor gets connected" type="bool" default="true">${toStr c.admin_console.logging.monitor_connect}</monitor_connect>
                  <admin_action desc="log when admin does some action for example killing a process" type="bool" default="true">${toStr c.admin_console.logging.admin_action}</admin_action>
              </logging>
          </admin_console>

          <monitors desc="Addresses of servers we connect to on start for monitoring">
              <!-- <monitor desc="Address of the monitor and interval after which it should try reconnting after disconnect" retryInterval="20">wss://foobar:234/ws</monitor> -->
              ${
                lib.concatLines (
                  map (
                    monitor:
                    ''<monitor retryInterval="${toStr monitor.retryInterval}">${toStr monitor.address}</monitor>''
                  ) c.monitors
                )
              }
          </monitors>

          <quarantine_files desc="Files are stored here to be examined later in cases of crashes or similar situation." default="false" enable="${toStr c.quarantine_files.enable}">
              <limit_dir_size_mb desc="Maximum directory size, in MBs. On exceeding the specified limit, older files will be deleted." default="250" type="uint">${toStr c.quarantine_files.limit_dir_size_mb}</limit_dir_size_mb>
              <max_versions_to_maintain desc="How many versions of the same file to keep." default="5" type="uint">${toStr c.quarantine_files.max_versions_to_maintain}</max_versions_to_maintain>
              <path desc="Absolute path of the directory under which quarantined files will be stored. Do not use a relative path." type="path" relative="false">${lib.optionalString c.quarantine_files.enable (toStr c.quarantine_files.path)}</path>
              <expiry_min desc="Time in mins after quarantined files will be deleted." type="int" default="3000">${toStr c.quarantine_files.expiry_min}</expiry_min>
          </quarantine_files>

          <remote_config>
              <remote_url desc="remote server to which you will send request to get remote config in response" type="string" default="">${toStr c.remote_config.remote_url}</remote_url>
          </remote_config>

          <stop_on_config_change desc="Stop coolwsd whenever config files change." type="bool" default="false">${toStr c.stop_on_config_change}</stop_on_config_change>

          <remote_font_config>
              <url desc="URL of optional JSON file that lists fonts to be included in Online" type="string" default="">${toStr c.remote_font_config.url}</url>
          </remote_font_config>

          <home_mode>
              <enable desc="Enable more configuration options for home users" type="bool" default="false">${toStr c.home_mode.enable}</enable>
          </home_mode>

          <fonts_missing>
              <handling desc="How to handle fonts mising in a document: 'report', 'log', 'both', or 'ignore'" type="string" default="log">${toStr c.fonts_missing.handling}</handling>
          </fonts_missing>

          <indirection_endpoint>
            <url desc="URL endpoint to server which servers routeToken in json format" default="">${toStr c.indirection_endpoint.url}</url>
            <migration_timeout_secs desc="The maximum number of seconds waiting for shutdown migration message from indirection server before unloading an document. Defaults to 180 second." type="uint" default="180">${toStr c.indirection_endpoint.migration_timeout_secs}</migration_timeout_secs>
          </indirection_endpoint>

          <!-- @LOCK_CONFIGURATION@ -->

          <!-- @FEATURE_RESTRICTION_CONFIGURATION@ -->

          <zotero desc="Zotero plugin configuration. For more details about Zotero visit https://www.zotero.org/">
              <enable desc="Enable Zotero plugin." type="bool" default="true">${toStr c.zotero.enable}</enable>
          </zotero>

          <help_url desc="The Help root URL, or empty for no help (hides the Help buttons)" type="string" default="https://help.collaboraoffice.com/help.html">${toStr c.help_url}</help_url>

          <overwrite_mode>
              <enable desc="Enable overwrite mode (user can use insert key)" type="bool" default="true">${toStr c.overwrite_mode.enable}</enable>
          </overwrite_mode>

          <wasm desc="WASM-specific settings">
              <enable desc="Enable WASM support" type="bool" default="false">${toStr c.wasm.enable}</enable>
              <force desc="When enabled, all requests are redirected to WASM." type="bool" default="false">${toStr c.wasm.force}</force>
          </wasm>

      </config>
    '';

  upstreamdoc = ''
    See [upstream example](https://github.com/CollaboraOnline/online/blob/master/coolwsd.xml.in) for the reference.
  '';

  logging_level_type = lib.types.oneOf [
    (lib.types.ints.between 0 8)
    (lib.types.enum [
      "none" # 0
      "fatal" # 1
      "critical" # 2
      "error" # 3
      "warning" # 4
      "notice" # 5
      "information" # 6
      "debug" # 7
      "trace" # 8
    ])
  ];
in
{
  options.services.collabora-online = {
    enable = lib.mkEnableOption "collabora-online";

    package = lib.mkPackageOption pkgs "collabora-online" { };

    port = lib.mkOption {
      type = lib.types.port;
      default = 9980;
      description = "Listening port";
    };

    config = {
      # Accessibility settings
      accessibility = {
        enable = lib.mkEnableOption "accessibility support";
      };

      allowed_languages = lib.mkOption {
        type = lib.types.listOf lib.types.str;
        default = [
          "de_DE"
          "en_GB"
          "en_US"
          "es_ES"
          "fr_FR"
          "it"
          "nl"
          "pt_BR"
          "pt_PT"
          "ru"
        ];
        description = ''List of supported languages of Writing Aids (spell checker, grammar checker, thesaurus, hyphenation) on this instance. Allowing too many has negative effect on startup performance.'';
      };

      # Remote API settings for spell and grammar checking.
      # These are the settings of external (remote) spellchecker and grammar checker services. Currently LanguageTool and Duden Korrekturserver APIs are supported, you can
      # set either of them. By default they are disabled. To turn the support on, please set "enabled" property to true. It works with self hosted or cloud services, free
      # and premium as well. The "base_url" may be https://api.languagetoolplus.com/v2 if the cloud version of LanguageTool is used. Please note that your data in the
      # document e.g. the text part of it will be sent to the cloud API. Please read the respective privacy policies, e.g. https://languagetool.org/legal/privacy.
      languagetool = {
        enabled = lib.mkEnableOption ''Remote Spell and Grammar Checker'';

        base_url = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''HTTP endpoint for the API server, without /check or /languages postfix at the end.'';
        };

        user_name = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''LanguageTool or Duden account username for premium usage.'';
        };

        api_key = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''API key provided by LanguageTool or Duden account for premium usage.'';
        };

        ssl_verification = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Enable or disable SSL verification. You may have to disable it in test environments with self-signed certificates.'';
        };

        rest_protocol = lib.mkOption {
          type = lib.types.enum [
            ""
            "duden"
          ];
          default = "";
          description = ''REST API protocol. For LanguageTool leave it blank, for Duden Korrekturserver use the string 'duden'.'';
        };
      };

      # DeepL API settings for translation service
      deepl = {
        enabled = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''If true, shows translate option as a menu entry in the compact view and as an icon in the tabbed view.'';
        };

        api_url = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''URL for the API.'';
        };

        auth_key = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''Auth Key generated by your account.'';
        };
      };

      mount_jail_tree = lib.mkOption {
        type = lib.types.bool;
        default = true;
        description = ''Controls whether the systemplate and lotemplate contents are mounted or not, which is much faster than the default of linking/copying each file.'';
      };

      mount_namespaces = lib.mkOption {
        type = lib.types.bool;
        default = false;
        description = ''Use mount namespaces instead of coolmount.'';
      };

      server_name = lib.mkOption {
        type = lib.types.str;
        default = "";
        description = ''External hostname:port of the server running coolwsd. If empty, it's derived from the request (please set it if this doesn't work). May be specified when behind a reverse-proxy or when the hostname is not reachable directly.'';
      };

      hexify_embedded_urls = lib.mkOption {
        type = lib.types.bool;
        default = false;
        description = ''Enable to protect encoded URLs from getting decoded by intermediate hops. Particularly useful on Azure deployments.'';
      };

      experimental_features = lib.mkOption {
        type = lib.types.bool;
        default = false;
        description = ''Enable/Disable experimental features.'';
      };

      memproportion = lib.mkOption {
        type = lib.types.numbers.between 0.0 100.0;
        default = 80.0;
        description = ''The maximum percentage of available memory consumed by all of the Collabora Online Development Edition processes, after which we start cleaning up idle documents. If cgroup memory limits are set, this is the maximum percentage of that limit to consume.'';
      };

      num_prespawn_children = lib.mkOption {
        type = lib.types.ints.unsigned;
        default = 4;
        description = ''Number of child processes to keep started in advance and waiting for new clients.'';
      };

      # Document-specific settings, including LO Core settings.
      per_document = {
        max_concurrency = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 4;
          description = ''The maximum number of threads to use while processing a document.'';
        };

        batch_priority = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 5;
          description = ''A (lower) priority for use by batch eg. convert-to processes to avoid starving interactive ones.'';
        };

        bgsave_priority = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 5;
          description = ''A (lower) priority for use by background save processes to free time for interactive ones.'';
        };

        redlining_as_comments = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''If true show red-lines as comments.'';
        };

        pdf_resolution_dpi = lib.mkOption {
          type = lib.types.ints.between 1 384;
          default = 96;
          description = ''The resolution, in DPI, used to render PDF documents as image. Memory consumption grows proportionally. Must be a positive value less than 385. Defaults to 96.'';
        };

        idle_timeout_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 3600;
          description = ''The maximum number of seconds before unloading an idle document. Defaults to 1 hour.'';
        };

        idlesave_duration_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 30;
          description = ''The number of idle seconds after which document, if modified, should be saved. Disabled when 0. Defaults to 30 seconds.'';
        };

        autosave_duration_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 300;
          description = ''The number of seconds after which document, if modified, should be saved. Disabled when 0. Defaults to 5 minutes.'';
        };

        background_autosave = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Allow auto-saves to occur in a forked background process where possible.'';
        };

        background_manualsave = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Allow manual save to occur in a forked background process where possible.'';
        };

        always_save_on_exit = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''On exiting the last editor, always perform a save and upload if the document had been modified. This is to allow the storage to store the document, if it had skipped doing so, previously, as an optimization.'';
        };

        limit_virt_mem_mb = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 0;
          description = ''The maximum virtual memory allowed to each document process. 0 for unlimited.'';
        };

        limit_stack_mem_kb = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 8000;
          description = ''The maximum stack size allowed to each document process. 0 for unlimited.'';
        };

        limit_file_size_mb = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 0;
          description = ''The maximum file size allowed to each document process to write. 0 for unlimited.'';
        };

        limit_num_open_files = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 0;
          description = ''The maximum number of files allowed to each document process to open. 0 for unlimited.'';
        };

        limit_load_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 100;
          description = ''Maximum number of seconds to wait for a document load to succeed. 0 for unlimited.'';
        };

        limit_store_failures = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 5;
          description = ''Maximum number of consecutive save-and-upload to storage failures when unloading the document. 0 for unlimited (not recommended).'';
        };

        limit_convert_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 100;
          description = ''Maximum number of seconds to wait for a document conversion to succeed. 0 for unlimited.'';
        };

        min_time_between_saves_ms = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 500;
          description = ''Minimum number of milliseconds between saving the document on disk.'';
        };

        min_time_between_uploads_ms = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 5000;
          description = ''Minimum number of milliseconds between uploading the document to storage.'';
        };

        # Checks for resource consuming (bad) documents and kills associated kit process. A document is considered resource consuming (bad) if is in idle state for idle_time_secs period and memory usage passed limit_dirty_mem_mb or CPU usage passed limit_cpu_per
        cleanup = {
          enable = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Checks for resource consuming (bad) documents and kills associated kit process. A document is considered resource consuming (bad) if is in idle state for idle_time_secs period and memory usage passed limit_dirty_mem_mb or CPU usage passed limit_cpu_per.'';
          };

          cleanup_interval_ms = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 10000;
            description = ''Interval between two checks.'';
          };

          bad_behavior_period_secs = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 60;
            description = ''Minimum time period for a document to be in bad state before associated kit process is killed. If in this period the condition for bad document is not met once then this period is reset.'';
          };

          idle_time_secs = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 300;
            description = ''Minimum idle time for a document to be candidate for bad state.'';
          };

          limit_dirty_mem_mb = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 3072;
            description = ''Minimum memory usage for a document to be candidate for bad state.'';
          };

          limit_cpu_per = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 85;
            description = ''Minimum CPU usage for a document to be candidate for bad state.'';
          };

          lost_kit_grace_period_secs = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 120;
            description = ''The minimum grace period for a lost kit process (not referenced by coolwsd) to resolve its lost status before it is terminated. To disable the cleanup of lost kits use value 0.'';
          };
        };
      };

      # View-specific settings.
      per_view = {
        out_of_focus_timeout_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 300;
          description = ''The maximum number of seconds before dimming and stopping updates when the browser tab is no longer in focus. Defaults to 300 seconds.'';
        };

        idle_timeout_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 900;
          description = ''The maximum number of seconds before dimming and stopping updates when the user is no longer active (even if the browser is in focus). Defaults to 15 minutes.'';
        };

        custom_os_info = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''Custom string shown as OS version in About dialog, get from system if empty.'';
        };
      };

      ver_suffix = lib.mkOption {
        type = lib.types.str;
        default = "";
        description = ''Appended to etags to allow easy refresh of changed files during development.'';
      };

      logging = {
        color = lib.mkOption {
          type = lib.types.bool;
          description = ''Enable colored logging output.'';
          default = true;
        };

        level = lib.mkOption {
          type = logging_level_type;
          default = "warning";
          description = ''Can be 0-8 (with the lowest numbers being the least verbose), or none (turns off logging), fatal, critical, error, warning, notice, information, debug, trace.'';
        };

        level_startup = lib.mkOption {
          type = logging_level_type;
          default = "trace";
          description = ''As for level - but for the initial startup phase which is most problematic, logging reverts to level configured above when startup is complete.'';
        };

        disabled_areas = lib.mkOption {
          type = lib.types.listOf (
            lib.types.enum [
              "Generic"
              "Pixel"
              "Socket"
              "WebSocket"
              "Http"
              "WebServer"
              "Storage"
              "WOPI"
              "Admin"
              "Javascript"
            ]
          );
          default = [
            "Socket"
            "WebSocket"
            "Admin"
          ];
          description = ''High verbosity logging ie. info to trace are disable-able.'';
        };

        most_verbose_level_settable_from_client = lib.mkOption {
          type = logging_level_type;
          default = "notice";
          description = ''A loggingleveloverride message from the client can not set a more verbose log level than this.'';
        };

        least_verbose_level_settable_from_client = lib.mkOption {
          type = logging_level_type;
          default = "fatal";
          description = ''A loggingleveloverride message from a client can not set a less verbose log level than this.'';
        };

        protocol = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable minimal client-site JS protocol logging from the start.'';
        };

        lokit_sal_log = lib.mkOption {
          type = lib.types.str;
          default = "-INFO-WARN";
          example = "+TIMESTAMP+INFO.ucb.ucp.webdav+WARN.ucb.ucp.webdav";
          description = ''
            Fine tune log messages from LOKit. Default is to suppress log messages from LOKit.
            Example: Log WebDAV-related messages, that is interesting for debugging Insert - Image operation: "+TIMESTAMP+INFO.ucb.ucp.webdav+WARN.ucb.ucp.webdav".
          '';
        };

        file = {
          enable = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Enable logging to a file.'';
          };

          path = lib.mkOption {
            type = lib.types.path;
            default = "/var/log/coolwsd.log";
            description = ''Log file path.'';
          };

          rotation = lib.mkOption {
            type = lib.types.nonEmptyStr;
            default = "never";
            description = ''Log file rotation strategy. See Poco FileChannel.'';
          };

          archive = lib.mkOption {
            type = lib.types.enum [
              "number"
              "timestamp"
            ];
            default = "timestamp";
            description = ''Append either timestamp or number to the archived log filename.'';
          };

          compress = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Enable/disable log file compression.'';
          };

          purgeAge = lib.mkOption {
            type = lib.types.nonEmptyStr;
            default = "10 days";
            description = ''The maximum age of log files to preserve. See Poco FileChannel.'';
          };

          purgeCount = lib.mkOption {
            type = lib.types.either lib.types.ints.unsigned (lib.types.enum [ "none" ]);
            default = 10;
            description = ''The maximum number of log archives to preserve. Use 'none' to disable purging. See Poco FileChannel.'';
          };

          rotateOnOpen = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Enable/disable log file rotation on opening.'';
          };

          flush = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Enable/disable flushing after logging each line. May harm performance. Note that without flushing after each line, the log lines from the different processes will not appear in chronological order.'';
          };
        };

        anonymize = {
          anonymize_user_data = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Enable to anonymize/obfuscate of user-data in logs. If default is true, it was forced at compile-time and cannot be disabled.'';
          };

          anonymization_salt = lib.mkOption {
            type = lib.types.ints.unsigned; # NOTE: the biggest int Nix accepts is 2^63 - 1
            default = 82589933;
            description = ''The salt used to anonymize/obfuscate user-data in logs. Use a secret 64-bit random number.'';
          };
        };

        docstats = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable to see document handling information in logs.'';
        };

        userstats = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable user stats. i.e: logs the details of a file and user.'';
        };

        disable_server_audit = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Disabled server audit dialog and notification. Admin will no longer see warnings in the application user interface. This doesn't affect log file.'';
        };
      };

      # The possibility to turn on generation of a Chrome Trace Event file
      trace_event = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''The possibility to turn on generation of a Chrome Trace Event file.'';
        };

        path = lib.mkOption {
          type = lib.types.path;
          default = "/var/log/coolwsd.trace.json";
          description = ''Output path for the Trace Event file, to which they will be written if turned on at run-time.'';
        };
      };

      browser_logging = lib.mkOption {
        type = lib.types.bool;
        default = false;
        description = ''Logging in the browser console.'';
      };

      trace = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Dump commands and notifications for replay.'';
        };

        path = {
          path = lib.mkOption {
            type = lib.types.path;
            example = "/some/path/to/cooltrace-%.gz";
            description = ''Output path to hold trace file and docs. Use '%' for timestamp to avoid overwriting.'';
          };

          compress = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Enable/disable trace file compression.'';
          };

          snapshot = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''When true, the source file is copied to the path first.'';
          };
        };

        filter = lib.mkOption {
          type = lib.types.listOf lib.types.nonEmptyStr;
          default = [ ];
          description = ''A list of regex pattern of messages to exclude.'';
        };

        outgoing = {
          record = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Whether or not to record outgoing messages.'';
          };
        };
      };

      # Network settings
      net = {
        proto = lib.mkOption {
          type = lib.types.enum [
            "IPv4"
            "IPv6"
            "all"
          ];
          default = "all";
          description = ''Protocol to use.'';
        };

        listen = lib.mkOption {
          type = lib.types.enum [
            "any"
            "loopback"
          ];
          default = "any";
          description = ''Listen address that coolwsd binds to. Can be 'any' or 'loopback'.'';
        };

        service_root = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''Prefix all the pages, websockets, etc. with this path.'';
        };

        # Allow/deny client IP address for POST(REST).
        post_allow = {
          allow = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Allow/deny client IP address for POST(REST).'';
          };

          hosts = lib.mkOption {
            type = lib.types.listOf lib.types.str;
            default = [
              ''192\.168\.[0-9]{1,3}\.[0-9]{1,3}'' # ............ The IPv4 private 192.168 block as plain IPv4 dotted decimal addresses.
              ''::ffff:192\.168\.[0-9]{1,3}\.[0-9]{1,3}'' # ..... Ditto, but as IPv4-mapped IPv6 addresses
              ''127\.0\.0\.1'' # ................................ The IPv4 loopback (localhost) address.
              ''::ffff:127\.0\.0\.1'' # ......................... Ditto, but as IPv4-mapped IPv6 address
              ''::1'' # ......................................... The IPv6 loopback (localhost) address.
              ''172\.1[6789]\.[0-9]{1,3}\.[0-9]{1,3}'' # ........ The IPv4 private 172.16.0.0/12 subnet part 1.
              ''::ffff:172\.1[6789]\.[0-9]{1,3}\.[0-9]{1,3}'' # . Ditto, but as IPv4-mapped IPv6 addresses
              ''172\.2[0-9]\.[0-9]{1,3}\.[0-9]{1,3}'' # ......... The IPv4 private 172.16.0.0/12 subnet part 2.
              ''::ffff:172\.2[0-9]\.[0-9]{1,3}\.[0-9]{1,3}'' # .. Ditto, but as IPv4-mapped IPv6 addresses
              ''172\.3[01]\.[0-9]{1,3}\.[0-9]{1,3}'' # .......... The IPv4 private 172.16.0.0/12 subnet part 3.
              ''::ffff:172\.3[01]\.[0-9]{1,3}\.[0-9]{1,3}'' # ... Ditto, but as IPv4-mapped IPv6 addresses
              ''10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'' # ...... The IPv4 private 10.0.0.0/8 subnet (Podman).
              ''::ffff:10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'' # Ditto, but as IPv4-mapped IPv6 addresses
            ];
            description = upstreamdoc;
          };
        };

        lok_allow = lib.mkOption {
          type = lib.types.listOf lib.types.str;
          default = [
            ''192\.168\.[0-9]{1,3}\.[0-9]{1,3}'' # ............ The IPv4 private 192.168 block as plain IPv4 dotted decimal addresses.
            ''::ffff:192\.168\.[0-9]{1,3}\.[0-9]{1,3}'' # ..... Ditto, but as IPv4-mapped IPv6 addresses
            ''127\.0\.0\.1'' # ................................ The IPv4 loopback (localhost) address.
            ''::ffff:127\.0\.0\.1'' # ......................... Ditto, but as IPv4-mapped IPv6 address
            ''::1'' # ......................................... The IPv6 loopback (localhost) address.
            ''172\.1[6789]\.[0-9]{1,3}\.[0-9]{1,3}'' # ........ The IPv4 private 172.16.0.0/12 subnet part 1.
            ''::ffff:172\.1[6789]\.[0-9]{1,3}\.[0-9]{1,3}'' # . Ditto, but as IPv4-mapped IPv6 addresses
            ''172\.2[0-9]\.[0-9]{1,3}\.[0-9]{1,3}'' # ......... The IPv4 private 172.16.0.0/12 subnet part 2.
            ''::ffff:172\.2[0-9]\.[0-9]{1,3}\.[0-9]{1,3}'' # .. Ditto, but as IPv4-mapped IPv6 addresses
            ''172\.3[01]\.[0-9]{1,3}\.[0-9]{1,3}'' # .......... The IPv4 private 172.16.0.0/12 subnet part 3.
            ''::ffff:172\.3[01]\.[0-9]{1,3}\.[0-9]{1,3}'' # ... Ditto, but as IPv4-mapped IPv6 addresses
            ''10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'' # ...... The IPv4 private 10.0.0.0/8 subnet (Podman).
            ''::ffff:10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'' # Ditto, but as IPv4-mapped IPv6 addresses
            ''localhost'' # ................................... Localhost access by name
          ];
          description = ''Allowed hosts as an external data source inside edited files. All allowed post_allow.host and storage.wopi entries are also considered to be allowed as a data source. Used for example in: PostMessage Action_InsertGraphics, =WEBSERVICE() function, external reference in the cell.'';
        };

        content_security_policy = lib.mkOption {
          type = lib.types.listOf lib.types.str;
          default = [ ];
          description = ''Customize the CSP header by specifying one or more policy-directive, separated by semicolons. See w3.org/TR/CSP2.'';
        };

        connection_timeout_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 30;
          description = ''Specifies the connection, send, recv timeout in seconds for connections initiated by coolwsd (such as WOPI connections).'';
        };

        proxy_prefix = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''
            Enable a ProxyPrefix to be passed int through which to redirect requests.
            This setting radically changes how online works, it should not be used in a production environment.
          '';
        };
      };

      # SSL settings
      ssl = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''
            Controls whether SSL encryption between coolwsd and the network is enabled (do not disable for production deployment). If default is false, must first be compiled with SSL support to enable.
            Switches from https:// + wss:// to http:// + ws://.
          '';
        };

        termination = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Connection via proxy where coolwsd acts as working via https, but actually uses http.'';
        };

        cert_file_path = lib.mkOption {
          type = lib.types.path;
          default = "${config.services.collabora-online.package}/etc/coolwsd/cert.pem";
          defaultText = lib.literalExpression "\${config.services.collabora-online.package}/etc/coolwsd/cert.pem";
          description = ''Path to the cert file.'';
        };

        key_file_path = lib.mkOption {
          type = lib.types.path;
          default = "${config.services.collabora-online.package}/etc/coolwsd/key.pem";
          defaultText = lib.literalExpression "\${config.services.collabora-online.package}/etc/coolwsd/key.pem";
          description = ''Path to the key file.'';
        };

        ca_file_path = lib.mkOption {
          type = lib.types.path;
          default = "${config.services.collabora-online.package}/ca-chain.cert.pem";
          defaultText = lib.literalExpression "\${config.services.collabora-online.package}/ca-chain.cert.pem";
          description = ''Path to the ca file.'';
        };

        ssl_verification = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Enable or disable SSL verification of hosts remote to coolwsd. If true SSL verification will be strict, otherwise certs of hosts will not be verified. You may have to disable it in test environments with self-signed certificates.'';
        };

        cipher_list = lib.mkOption {
          type = lib.types.str;
          default = "ALL:!ADH:!LOW:!EXP:!MD5:@STRENGTH";
          description = ''List of OpenSSL ciphers to accept.'';
        };

        hpkp = {
          enable = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Enable HTTP Public key pinning.'';
          };

          report_only = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = upstreamdoc;
          };

          max_age = lib.mkOption {
            type = lib.types.nullOr lib.types.int;
            default = 1000;
            description = ''HPKP's max-age directive - time in seconds browser should remember the pins.'';
          };

          report_uri = lib.mkOption {
            type = lib.types.nullOr lib.types.str;
            default = null;
            description = ''HPKP's report-uri directive - pin validation failure are reported at this URL.'';
          };

          pins = lib.mkOption {
            type = lib.types.listOf lib.types.str;
            default = [ ];
            description = ''Base64 encoded SPKI fingerprints of keys to be pinned.'';
          };
        };

        # Strict-Transport-Security settings, per rfc6797. Subdomains are always included.
        sts = {
          enabled = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Whether or not Strict-Transport-Security is enabled. Enable only when ready for production. Cannot be disabled without resetting the browsers.'';
          };

          max_age = lib.mkOption {
            type = lib.types.int;
            default = 31536000;
            description = ''Strict-Transport-Security max-age directive, in seconds. 0 is allowed; please see rfc6797 for details. Defaults to 1 year.'';
          };
        };
      };

      # Altering these defaults potentially opens you to significant risk
      security = {
        seccomp = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Should we use the seccomp system call filtering.'';
        };

        capabilities = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Should we require capabilities to isolate processes into chroot jails.'';
        };

        jwt_expiry_secs = lib.mkOption {
          type = lib.types.int;
          default = 1800;
          description = ''Time in seconds before the Admin Console's JWT token expires.'';
        };

        enable_macros_execution = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Specifies whether the macro execution is enabled in general. This will enable Basic and Python scripts to execute both installed and from documents. If it is set to false, the macro_security_level is ignored. If it is set to true, the mentioned entry specified the level of macro security.'';
        };

        macro_security_level = lib.mkOption {
          type = lib.types.int;
          default = 1;
          description = ''Level of Macro security. 1 (Medium) Confirmation required before executing macros from untrusted sources. 0 (Low, not recommended) All macros will be executed without confirmation.'';
        };

        enable_websocket_urp = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Should we enable URP (UNO remote protocol) communication over the websocket. This allows full control of the Kit child server to anyone with access to the websocket including executing macros without confirmation or running arbitrary shell commands in the jail.'';
        };

        enable_metrics_unauthenticated = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''When enabled, the /cool/getMetrics endpoint will not require authentication.'';
        };
      };

      certificates = {
        database_path = lib.mkOption {
          type = lib.types.nullOr lib.types.path;
          default = null;
          description = ''Path to the NSS certificates that are used for signing documents.'';
        };
      };

      watermark = {
        opacity = lib.mkOption {
          type = lib.types.numbers.between 0.0 1.0;
          default = 0.2;
          description = ''Opacity of on-screen watermark.'';
        };

        text = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''Watermark text to be displayed on the document if entered.'';
        };
      };

      welcome = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Controls whether the welcome screen should be shown to the users on new install and updates.'';
        };
      };

      user_interface = {
        mode = lib.mkOption {
          type = lib.types.enum [
            "default"
            "compact"
            "tabbed"
          ];
          default = "default";
          description = ''Controls the user interface style. The 'default' means: Take the value from ui_defaults, or decide for one of compact or tabbed (default|compact|tabbed).'';
        };

        use_integration_theme = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Use theme from the integrator'';
        };
      };

      # Backend storage
      storage = {
        filesystem = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = upstreamdoc;
        };

        wopi = {
          allow = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''Allow/deny wopi storage.'';
          };

          max_file_size = lib.mkOption {
            type = lib.types.ints.unsigned;
            default = 0;
            description = ''Maximum document size in bytes to load. 0 for unlimited.'';
          };

          # Locking settings
          locking = {
            refresh = lib.mkOption {
              type = lib.types.ints.unsigned;
              default = 900;
              description = ''How frequently we should re-acquire a lock with the storage server, in seconds or 0 for no refresh.'';
            };
          };

          alias_groups = lib.mkOption {
            type = lib.types.nullOr (
              lib.types.listOf (
                lib.types.submodule {
                  options = {
                    allow = lib.mkOption {
                      type = lib.types.bool;
                      default = true;
                      description = ''Whether allow or deny hostname'';
                    };

                    host = lib.mkOption {
                      type = lib.types.str;
                      example = ''scheme://hostname:port'';
                      description = ''Hostname to allow or deny.'';
                    };

                    aliases = lib.mkOption {
                      type = lib.types.listOf lib.types.str;
                      default = [ ];
                      example = [
                        "scheme://aliasname1:port"
                        "scheme://aliasname2:port"
                      ];
                      description = ''A list of regex pattern of aliasname.'';
                    };
                  };
                }
              )
            );
            default = null;
            example = [
              {
                allow = true;
                host = "https://example.com";
                aliases = [ ];
              }
            ];
            description = ''
              A list of allowed WOPI hosts to access from.
              When null, the 'first' mode is used that allows only the first host.
            '';
          };

          is_legacy_server = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''Set to true for legacy server that need deprecated headers.'';
          };
        };

        # SSL settings
        ssl = {
          as_scheme = lib.mkOption {
            type = lib.types.nullOr lib.types.bool;
            default = true;
            description = ''When set we exclusively use the WOPI URI's scheme to enable SSL for storage.'';
          };

          enable = lib.mkOption {
            type = lib.types.nullOr lib.types.bool;
            default = null;
            description = ''If as_scheme is false or not set, this can be set to force SSL encryption between storage and coolwsd. When empty this defaults to following the ssl.enable setting.'';
          };

          cert_file_path = lib.mkOption {
            type = lib.types.nullOr lib.types.path;
            default = null;
            description = ''Path to the cert file. When empty this defaults to following the ssl.cert_file_path setting.'';
          };

          key_file_path = lib.mkOption {
            type = lib.types.nullOr lib.types.path;
            default = null;
            description = ''Path to the key file. When empty this defaults to following the ssl.key_file_path settinge.'';
          };

          ca_file_path = lib.mkOption {
            type = lib.types.nullOr lib.types.path;
            default = null;
            description = ''Path to the ca file. When empty this defaults to following the ssl.ca_file_path setting.'';
          };

          cipher_list = lib.mkOption {
            type = lib.types.nullOr lib.types.str;
            default = null;
            description = ''List of OpenSSL ciphers to accept. If empty the defaults are used. These can be overridden only if absolutely needed.'';
          };
        };
      };

      # Web admin console settings.
      admin_console = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Enable the admin console functionality.'';
        };

        enable_pam = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable admin user authentication with PAM.'';
        };

        username = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''The username of the admin console. Ignored if PAM is enabled.'';
        };

        password = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''The password of the admin console. Deprecated on most platforms. Instead, use PAM or coolconfig to set up a secure password.'';
        };

        # Log admin activities irrespective of logging.level
        logging = {
          admin_login = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''log when an admin logged into the console.'';
          };

          metrics_fetch = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''log when metrics endpoint is accessed and metrics endpoint authentication is enabled.'';
          };

          monitor_connect = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''log when external monitor gets connected.'';
          };

          admin_action = lib.mkOption {
            type = lib.types.bool;
            default = true;
            description = ''log when admin does some action for example killing a process.'';
          };
        };
      };

      monitors = lib.mkOption {
        type = lib.types.listOf (
          lib.types.submodule {
            options = {
              address = lib.mkOption {
                type = lib.types.str;
                example = "wss://foobar:234/ws";
                description = "Address of the monitor";
              };

              retryInterval = lib.mkOption {
                type = lib.types.ints.unsigned;
                example = 20;
                description = "Interval after which it should try reconnting after disconnect";
              };
            };
          }
        );
        default = [ ];
        description = "Addresses of servers we connect to on start for monitoring";
      };

      # Files are stored here to be examined later in cases of crashes or similar situation.
      quarantine_files = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = upstreamdoc;
        };

        limit_dir_size_mb = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 250;
          description = ''Maximum directory size, in MBs. On exceeding the specified limit, older files will be deleted.'';
        };

        max_versions_to_maintain = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 5;
          description = ''How many versions of the same file to keep.'';
        };

        path = lib.mkOption {
          type = lib.types.path;
          description = ''Path of the directory under which quarantined files will be stored.'';
        };

        expiry_min = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 3000;
          description = ''Time in mins after quarantined files will be deleted.'';
        };
      };

      stop_on_config_change = lib.mkOption {
        type = lib.types.bool;
        default = false;
        description = ''Stop coolwsd whenever config files change.'';
      };

      remote_config = {
        remote_url = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''remote server to which you will send request to get remote config in response.'';
        };
      };

      remote_font_config = {
        url = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''URL of optional JSON file that lists fonts to be included in Online.'';
        };
      };

      home_mode = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable more configuration options for home users.'';
        };
      };

      fonts_missing = {
        handling = lib.mkOption {
          type = lib.types.enum [
            "report"
            "log"
            "both"
            "ingore"
          ];
          default = "log";
          description = "How to handle fonts mising in a document: 'report', 'log', 'both', or 'ignore'";
        };
      };

      indirection_endpoint = {
        url = lib.mkOption {
          type = lib.types.str;
          default = "";
          description = ''URL endpoint to server which servers routeToken in json format.'';
        };

        migration_timeout_secs = lib.mkOption {
          type = lib.types.ints.unsigned;
          default = 180;
          description = ''The maximum number of seconds waiting for shutdown migration message from indirection server before unloading an document. Defaults to 180 second.'';
        };
      };

      zotero = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Enable Zotero plugin.'';
        };
      };

      help_url = lib.mkOption {
        type = lib.types.str;
        default = "https://help.collaboraoffice.com/help.html";
        description = ''The Help root URL, or empty for no help (hides the Help buttons).'';
      };

      overwrite_mode = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = true;
          description = ''Enable overwrite mode (user can use insert key).'';
        };
      };

      wasm = {
        enable = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''Enable WASM support.'';
        };

        force = lib.mkOption {
          type = lib.types.bool;
          default = false;
          description = ''When enabled, all requests are redirected to WASM.'';
        };
      };
    };
  };

  config = lib.mkIf cfg.enable {
    users.users.cool = {
      isSystemUser = true;
      group = "cool";
    };
    users.groups.cool = { };

    security.wrappers = {
      coolforkit = {
        owner = "root";
        group = "root";
        source = "${cfg.package}/bin/coolforkit";
        capabilities = "cap_fowner,cap_chown,cap_sys_chroot=ep";
      };

      coolmount = {
        owner = "root";
        group = "root";
        source = "${cfg.package}/bin/coolmount";
        capabilities = "cap_sys_admin=ep";
      };
    };

    systemd.services.coolwsd-systemplate-setup = {
      description = "Collabora Online WebSocket Daemon Setup";
      wantedBy = [ "multi-user.target" ];
      serviceConfig = {
        ExecStart = utils.escapeSystemdExecArgs [
          "${cfg.package}/bin/coolwsd-systemplate-setup"
          "/var/lib/cool/systemplate"
          "${cfg.package.libreoffice}/lib/collaboraoffice"
        ];
        RemainAfterExit = true;
        StateDirectory = "cool";
        Type = "oneshot";
        User = "cool";
      };
    };

    systemd.services.coolwsd = {
      description = "Collabora Online WebSocket Daemon";
      wantedBy = [ "multi-user.target" ];
      after = [
        "network.target"
        "coolwsd-systemplate-setup.service"
      ];
      serviceConfig = {
        ExecStart = utils.escapeSystemdExecArgs [
          "${cfg.package}/bin/coolwsd"
          "--config-file=${configFile}"
          "--port=${toString cfg.port}"
          "--version"
        ];
        KillMode = "mixed";
        KillSignal = "SIGINT";
        LimitNOFILE = "infinity:infinity";
        Restart = "always";
        StateDirectory = "cool";
        TimeoutStopSec = 120;
        User = "cool";
      };
    };
  };

  meta.maintainers = [ lib.maintainers.xzfc ];
}
