{
  config,
  lib,
  pkgs,
  ...
}:
let
  cfg = config.services.tun2socks;
  settingsFormat = pkgs.formats.yaml { };
in
with lib;
{
  options = {
    services.tun2socks = {
      enable = mkEnableOption "tun2socks daemon, allow to use proxies through virtual TUN interface.";
      user = mkOption {
        type = types.str;
        default = "tun2socks";
        description = "User account under which tun2socks runs.";
      };

      group = mkOption {
        type = types.str;
        default = "tun2socks";
        description = "Group account under which tun2socks runs.";
      };

      settings = mkOption {
        description = ''
          Configuration for tun2socks, see <https://github.com/xjasonlyu/tun2socks/wiki#usage>
          for more information.
        '';
        default = { };
        example = literalExpression ''
          {
            device = "eth0";
            fwmark = 1;
            proxy = "http://192.168.1.1:1080";
          }
        '';
        type = types.submodule {
          freeformType = settingsFormat.type;
          options = {
            device = mkOption {
              type = types.str;
              example = "tun0";
              description = "The tun device to use.";
            };
            proxy = mkOption {
              type = types.str;
              example = "socks5://192.168.1.1:1080";
              description = "The proxy to use [protocol://]host[:port]";
            };
          };
        };
      };

      configFile = mkOption {
        default = settingsFormat.generate "/var/lib/tun2socks/config.yaml" cfg.settings;
        defaultText = "A tun2socks configuration file automatically generated by values from services.tun2socks.settings.*";
        type = types.path;
        description = "Path to tun2socks YAML configuration file.";
      };

      package = mkOption {
        default = pkgs.tun2socks;
        defaultText = literalExpression "pkgs.tun2socks";
        type = types.package;
        description = "tun2socks package to use.";
      };
    };
  };

  config = mkIf cfg.enable {
    systemd.services.tun2socks = {
      description = "tun2socks";
      wants = [ "network-online.target" ];
      after = [ "network-online.target" ];
      wantedBy = [ "multi-user.target" ];
      serviceConfig = {
        User = cfg.user;
        Group = cfg.group;
        Type = "simple";
        ExecStart = "${getBin cfg.package}/bin/tun2socks -config ${cfg.configFile}";
        Restart = "always";

        # NET_ADMIN to operate the network devices
        AmbientCapabilities = [ "CAP_NET_ADMIN" ];
        StateDirectory = "tun2socks";
        StateDirectoryMode = "0750";
      };
    };

    users.users = optionalAttrs (cfg.user == "tun2socks") {
      tun2socks = {
        group = cfg.group;
        isSystemUser = true;
      };
    };

    users.groups = optionalAttrs (cfg.group == "tun2socks") {
      tun2socks = { };
    };
  };
}
